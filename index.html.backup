<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kannan Kalyani — Construction Logistics & Services</title>
    <meta name="description"
        content="Kannan Kalyani Construction Logistics & Services — Reliable delivery of M-Sand, P-Sand, Crushed Metal, Gravel and more. Serving Kollam, Kallada, Munroe Thuruth & nearby areas." />

    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                        display: ['Outfit', 'system-ui', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            50: '#FFF8E1', 100: '#FFECB3', 200: '#FFE082',
                            300: '#FFD54F', 400: '#FFCA28', 500: '#FFC107',
                            600: '#FFB300', 700: '#FFA000', 800: '#FF8F00', 900: '#FF6F00',
                        },
                        surface: {
                            50: '#FAFAFA', 100: '#F5F5F5', 200: '#EEEEEE',
                            300: '#E0E0E0', 400: '#BDBDBD', 500: '#9E9E9E',
                            600: '#757575', 700: '#616161', 800: '#424242',
                            900: '#212121', 950: '#121212',
                        }
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.6s ease-out both',
                        'slide-up': 'slideUp 0.6s ease-out both',
                        'slide-in-left': 'slideInLeft 0.5s ease-out both',
                        'slide-in-right': 'slideInRight 0.5s ease-out both',
                        'scale-in': 'scaleIn 0.4s ease-out both',
                        'float': 'float 6s ease-in-out infinite',
                        'pulse-glow': 'pulseGlow 2s ease-in-out infinite',
                        'spin': 'spin 1s linear infinite',
                    },
                    keyframes: {
                        fadeIn: { '0%': { opacity: '0' }, '100%': { opacity: '1' } },
                        slideUp: { '0%': { opacity: '0', transform: 'translateY(28px)' }, '100%': { opacity: '1', transform: 'translateY(0)' } },
                        slideInLeft: { '0%': { opacity: '0', transform: 'translateX(-36px)' }, '100%': { opacity: '1', transform: 'translateX(0)' } },
                        slideInRight: { '0%': { opacity: '0', transform: 'translateX(36px)' }, '100%': { opacity: '1', transform: 'translateX(0)' } },
                        scaleIn: { '0%': { opacity: '0', transform: 'scale(0.92)' }, '100%': { opacity: '1', transform: 'scale(1)' } },
                        float: { '0%,100%': { transform: 'translateY(0)' }, '50%': { transform: 'translateY(-10px)' } },
                        pulseGlow: { '0%,100%': { boxShadow: '0 0 20px rgba(255,193,7,.25)' }, '50%': { boxShadow: '0 0 40px rgba(255,193,7,.55)' } },
                        spin: { '100%': { transform: 'rotate(360deg)' } },
                    },
                },
            },
        }
    </script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@400;600;700;800;900&display=swap"
        rel="stylesheet" />

    <!-- Leaflet -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <!-- React 18 -->
    <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>

    <!-- Babel Standalone (for JSX transformation in browser) -->
    <script src="https://unpkg.com/@babel/standalone@7.23.2/babel.min.js"></script>

    <style>
        /* ── Scrollbar ── */
        ::-webkit-scrollbar {
            width: 6px
        }

        ::-webkit-scrollbar-track {
            background: #121212
        }

        ::-webkit-scrollbar-thumb {
            background: #424242;
            border-radius: 10px
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #616161
        }

        html {
            scroll-behavior: smooth
        }

        ::selection {
            background: rgba(255, 193, 7, .3);
            color: #fff
        }

        /* ── Glass ── */
        .glass {
            background: rgba(255, 255, 255, .04);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, .08)
        }

        .glass-dark {
            background: rgba(0, 0, 0, .35);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, .06)
        }

        .glass-card {
            background: rgba(255, 255, 255, .03);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, .07);
            transition: all .3s cubic-bezier(.4, 0, .2, 1)
        }

        .glass-card:hover {
            background: rgba(255, 255, 255, .06);
            border-color: rgba(255, 193, 7, .2);
            transform: translateY(-4px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, .3)
        }

        /* ── Gradient text ── */
        .gradient-text {
            background: linear-gradient(135deg, #FFC107 0%, #FF8F00 50%, #FFC107 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text
        }

        /* ── Dot grid ── */
        .dot-pattern {
            background-image: radial-gradient(rgba(255, 255, 255, .04) 1px, transparent 1px);
            background-size: 30px 30px
        }

        /* ── Hero bg ── */
        .hero-bg {
            background:
                radial-gradient(ellipse at 20% 50%, rgba(255, 193, 7, .08) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 20%, rgba(255, 143, 0, .06) 0%, transparent 50%),
                radial-gradient(ellipse at 50% 80%, rgba(255, 111, 0, .04) 0%, transparent 50%)
        }

        /* ── Form inputs ── */
        .form-input {
            background: rgba(255, 255, 255, .05);
            border: 1px solid rgba(255, 255, 255, .1);
            border-radius: 12px;
            padding: 13px 16px;
            color: #fff;
            font-size: 14px;
            outline: none;
            width: 100%;
            transition: all .3s ease;
            -webkit-appearance: none;
            appearance: none;
            font-family: 'Inter', sans-serif;
            box-sizing: border-box
        }

        .form-input:focus {
            border-color: rgba(255, 193, 7, .5);
            box-shadow: 0 0 0 3px rgba(255, 193, 7, .1);
            background: rgba(255, 255, 255, .07)
        }

        .form-input option {
            background: #212121;
            color: #fff
        }

        .form-label {
            display: block;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: .06em;
            text-transform: uppercase;
            color: #9E9E9E;
            margin-bottom: 8px
        }

        /* ── Buttons ── */
        .btn-primary {
            background: linear-gradient(135deg, #FFC107 0%, #FF8F00 100%);
            color: #121212;
            font-weight: 700;
            padding: 13px 28px;
            border-radius: 12px;
            border: none;
            cursor: pointer;
            font-size: 14px;
            letter-spacing: .02em;
            transition: all .3s cubic-bezier(.4, 0, .2, 1);
            box-shadow: 0 4px 15px rgba(255, 193, 7, .3);
            font-family: 'Inter', sans-serif;
            display: inline-flex;
            align-items: center;
            gap: 8px
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(255, 193, 7, .45)
        }

        .btn-primary:active {
            transform: translateY(0)
        }

        .btn-primary:disabled {
            opacity: .6;
            cursor: not-allowed;
            transform: none
        }

        .btn-secondary {
            background: rgba(255, 255, 255, .06);
            color: #E0E0E0;
            font-weight: 600;
            padding: 13px 28px;
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, .1);
            cursor: pointer;
            font-size: 14px;
            transition: all .3s ease;
            font-family: 'Inter', sans-serif
        }

        .btn-secondary:hover {
            background: rgba(255, 255, 255, .1);
            border-color: rgba(255, 255, 255, .2)
        }

        /* ── Admin Table ── */
        .admin-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0
        }

        .admin-table thead th {
            background: rgba(255, 255, 255, .03);
            padding: 11px 16px;
            text-align: left;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: .06em;
            text-transform: uppercase;
            color: #757575;
            border-bottom: 1px solid rgba(255, 255, 255, .06)
        }

        .admin-table tbody td {
            padding: 13px 16px;
            border-bottom: 1px solid rgba(255, 255, 255, .04);
            font-size: 13px
        }

        .admin-table tbody tr:hover {
            background: rgba(255, 255, 255, .025)
        }

        .admin-table tbody tr:last-child td {
            border-bottom: none
        }

        /* ── Map ── */
        .map-wrap {
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, .08)
        }

        .leaflet-control-attribution {
            background: rgba(0, 0, 0, .7) !important;
            color: #757575 !important;
            font-size: 10px !important
        }

        .leaflet-control-attribution a {
            color: #FFC107 !important
        }

        /* ── Toast ── */
        .toast {
            position: fixed;
            bottom: 28px;
            right: 28px;
            padding: 14px 22px;
            border-radius: 12px;
            font-size: 13px;
            font-weight: 500;
            z-index: 9999;
            animation: slideUp .4s ease-out both;
            box-shadow: 0 10px 40px rgba(0, 0, 0, .45);
            display: flex;
            align-items: center;
            gap: 10px;
            font-family: 'Inter', sans-serif
        }

        .toast-success {
            background: linear-gradient(135deg, #1B5E20, #2E7D32);
            border: 1px solid rgba(76, 175, 80, .3)
        }

        .toast-error {
            background: linear-gradient(135deg, #B71C1C, #C62828);
            border: 1px solid rgba(244, 67, 54, .3)
        }

        /* ── Result shimmer ── */
        @keyframes shimmer {
            0% {
                background-position: -200% 0
            }

            100% {
                background-position: 200% 0
            }
        }

        .result-shimmer {
            background: linear-gradient(90deg, rgba(255, 193, 7, 0) 0%, rgba(255, 193, 7, .07) 50%, rgba(255, 193, 7, 0) 100%);
            background-size: 200% 100%;
            animation: shimmer 2.5s infinite linear
        }

        @keyframes countUp {
            from {
                opacity: 0;
                transform: translateY(8px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        .count-animate {
            animation: countUp .4s ease-out both
        }

        /* ── Stagger helpers ── */
        .stagger-1 {
            animation-delay: .08s
        }

        .stagger-2 {
            animation-delay: .16s
        }

        .stagger-3 {
            animation-delay: .24s
        }

        .stagger-4 {
            animation-delay: .32s
        }

        .stagger-5 {
            animation-delay: .40s
        }

        .stagger-6 {
            animation-delay: .48s
        }

        /* ── Spinner ── */
        .spinner {
            width: 16px;
            height: 16px;
            border: 2px solid rgba(0, 0, 0, .25);
            border-top-color: #000;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            display: inline-block
        }

        @keyframes spin {
            to {
                transform: rotate(360deg)
            }
        }
    </style>
</head>

<body class="bg-surface-950 text-white font-sans antialiased">
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect, useRef } = React;

        // ─── Measurement options ───────────────────────────────────────────────────────
        const FT_OPTIONS = [145, 150, 195, 200, 250];

        // ─── Default data (localStorage-backed) ──────────────────────────────────────
        const DEFAULT_MATERIALS = [
            { id: 1, name: "M-Sand", pricing_type: "per_ft", price_per_ft: 50, price_per_load: null, description: "Manufactured sand for plastering & brickwork", icon: "🏗️" },
            { id: 2, name: "P-Sand", pricing_type: "per_ft", price_per_ft: 55, price_per_load: null, description: "Plastering-grade fine sand", icon: "🧱" },
            { id: 3, name: "Crushed Metal", pricing_type: "per_ft", price_per_ft: 48, price_per_load: null, description: "Crushed stone aggregate for concrete", icon: "⛏️" },
            { id: 4, name: "Rock Boulders", pricing_type: "per_load", price_per_ft: null, price_per_load: 5000, description: "Large boulders for foundations", icon: "🪨" },
            { id: 5, name: "Gravel", pricing_type: "per_load", price_per_ft: null, price_per_load: 3000, description: "Natural gravel for road base & filling", icon: "🔹" },
            { id: 6, name: "Cutting Earth", pricing_type: "per_load", price_per_ft: null, price_per_load: 2500, description: "Excavated earth for land filling", icon: "🌍" },
            { id: 7, name: "Quarry Waste", pricing_type: "per_load", price_per_ft: null, price_per_load: 2000, description: "Quarry by-product for sub-base layers", icon: "🏔️" },
        ];
        const DEFAULT_LOCATIONS = [
            { id: 1, name: "Kollam", transport_rate: 1500, distance_km: 8 },
            { id: 2, name: "Kallada", transport_rate: 2500, distance_km: 22 },
            { id: 3, name: "Munroe Thuruth", transport_rate: 2500, distance_km: 20 },
            { id: 4, name: "Pavithreswaram", transport_rate: 2000, distance_km: 15 },
            { id: 5, name: "West Kallada", transport_rate: 3000, distance_km: 28 },
            { id: 6, name: "Shuttle (Local)", transport_rate: 1000, distance_km: 5 },
        ];

        function getMaterials() {
            try { const s = localStorage.getItem('kk_materials'); if (s) return JSON.parse(s); } catch (e) { }
            return DEFAULT_MATERIALS;
        }
        function saveMaterials(m) { localStorage.setItem('kk_materials', JSON.stringify(m)); }
        function getLocations() {
            try { const s = localStorage.getItem('kk_locations'); if (s) return JSON.parse(s); } catch (e) { }
            return DEFAULT_LOCATIONS;
        }
        function saveLocations(l) { localStorage.setItem('kk_locations', JSON.stringify(l)); }

        // Seed defaults on first visit
        if (!localStorage.getItem('kk_materials')) saveMaterials(DEFAULT_MATERIALS);
        if (!localStorage.getItem('kk_locations')) saveLocations(DEFAULT_LOCATIONS);

        // ─── Hash router ───────────────────────────────────────────────────────────────
        function useRoute() {
            const [page, setPage] = useState(() => window.location.hash.replace('#', '') || 'home');
            useEffect(() => {
                const h = () => setPage(window.location.hash.replace('#', '') || 'home');
                window.addEventListener('hashchange', h);
                return () => window.removeEventListener('hashchange', h);
            }, []);
            const navigate = p => { window.location.hash = p; };
            return [page, navigate];
        }

        // ─── Toast ─────────────────────────────────────────────────────────────────────
        function Toast({ message, type, onClose }) {
            useEffect(() => { const t = setTimeout(onClose, 3000); return () => clearTimeout(t); }, []);
            return (
                <div className={`toast ${type === 'success' ? 'toast-success' : 'toast-error'}`}>
                    {type === 'success' ? '✅' : '❌'} {message}
                </div>
            );
        }

        // ─── Navbar ────────────────────────────────────────────────────────────────────
        function Navbar({ page, navigate }) {
            const [open, setOpen] = useState(false);
            const links = [
                { id: 'home',       label: 'Home',       icon: '🏠' },
                { id: 'calculator', label: 'Calculator', icon: '🧮' },
                { id: 'logistics',  label: 'Daily Log',  icon: '📋' },
                { id: 'contact',    label: 'Contact',    icon: '📞' },
                { id: 'admin',      label: 'Admin',      icon: '⚙️' },
            ];
            const go = id => { navigate(id); setOpen(false); };
            return (
                <nav className="fixed top-0 left-0 right-0 z-50 glass-dark" style={{ borderBottom: '1px solid rgba(255,255,255,.05)' }}>
                    <div className="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
                        {/* Logo */}
                        <button onClick={() => go('home')} className="flex items-center gap-3">
                            <div style={{ background: 'linear-gradient(135deg,#FFC107,#FF8F00)', borderRadius: '10px', width: '36px', height: '36px', display: 'flex', alignItems: 'center', justifyContent: 'center', fontWeight: 900, color: '#121212', fontSize: '13px', flexShrink: 0 }}>KK</div>
                            <div className="hidden sm:block text-left leading-tight">
                                <div className="text-white font-bold text-sm">KANNAN KALYANI</div>
                                <div className="text-surface-500 text-xs">Construction Logistics</div>
                            </div>
                        </button>

                        {/* Desktop links */}
                        <div className="hidden md:flex items-center gap-1">
                            {links.map(l => (
                                <button key={l.id} onClick={() => go(l.id)}
                                    className={`px-4 py-2 rounded-xl text-sm font-medium transition-all relative ${page === l.id ? 'text-brand-400 bg-brand-500/10' : 'text-surface-400 hover:text-white hover:bg-white/5'}`}
                                >
                                    {l.label}
                                    {page === l.id && <span style={{ position: 'absolute', bottom: 0, left: '50%', transform: 'translateX(-50%)', width: '16px', height: '2px', background: 'linear-gradient(90deg,#FFC107,#FF8F00)', borderRadius: '2px' }} />}
                                </button>
                            ))}
                            <button onClick={() => go('calculator')}
                                className="ml-3 px-4 py-2 rounded-xl text-sm font-bold text-surface-950 transition-all hover:-translate-y-0.5"
                                style={{ background: 'linear-gradient(135deg,#FFC107,#FF8F00)', boxShadow: '0 4px 15px rgba(255,193,7,.3)' }}
                            >
                                Get Estimate
                            </button>
                        </div>

                        {/* Mobile burger */}
                        <button className="md:hidden w-10 h-10 flex flex-col items-center justify-center gap-1.5 rounded-xl hover:bg-white/5 transition-colors" onClick={() => setOpen(o => !o)}>
                            <span style={{ width: '18px', height: '2px', background: '#E0E0E0', borderRadius: '2px', transition: 'all .3s', transform: open ? 'rotate(45deg) translateY(6px)' : 'none' }} />
                            <span style={{ width: '18px', height: '2px', background: '#E0E0E0', borderRadius: '2px', transition: 'all .3s', opacity: open ? 0 : 1 }} />
                            <span style={{ width: '18px', height: '2px', background: '#E0E0E0', borderRadius: '2px', transition: 'all .3s', transform: open ? 'rotate(-45deg) translateY(-6px)' : 'none' }} />
                        </button>
                    </div>

                    {/* Mobile menu */}
                    {open && (
                        <div className="md:hidden glass-dark px-4 pb-4" style={{ borderTop: '1px solid rgba(255,255,255,.05)' }}>
                            {links.map(l => (
                                <button key={l.id} onClick={() => go(l.id)}
                                    className={`w-full flex items-center gap-3 px-4 py-3 rounded-xl mb-1 text-sm font-medium transition-all text-left ${page === l.id ? 'text-brand-400 bg-brand-500/10' : 'text-surface-300 hover:bg-white/5'}`}
                                >
                                    <span>{l.icon}</span>{l.label}
                                </button>
                            ))}
                            <button onClick={() => go('calculator')}
                                className="w-full mt-2 py-3 rounded-xl text-sm font-bold text-surface-950"
                                style={{ background: 'linear-gradient(135deg,#FFC107,#FF8F00)' }}
                            >
                                🧮 Get Estimate
                            </button>
                        </div>
                    )}
                </nav>
            );
        }

        // ─── Footer ────────────────────────────────────────────────────────────────────
        function Footer({ navigate }) {
            const go = p => { window.location.hash = p; window.scrollTo({ top: 0, behavior: 'smooth' }); };
            return (
                <footer className="mt-20 py-10 px-4" style={{ borderTop: '1px solid rgba(255,255,255,.05)' }}>
                    <div className="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6 text-center md:text-left">
                        <div className="flex items-center gap-3">
                            <div style={{ background: 'linear-gradient(135deg,#FFC107,#FF8F00)', borderRadius: '8px', width: '32px', height: '32px', display: 'flex', alignItems: 'center', justifyContent: 'center', fontWeight: 900, color: '#121212', fontSize: '11px', flexShrink: 0 }}>KK</div>
                            <div>
                                <div className="text-white font-bold text-sm">KANNAN KALYANI</div>
                                <div className="text-surface-500 text-xs">Construction Logistics & Services</div>
                            </div>
                        </div>
                        <div className="flex gap-5 text-sm text-surface-500">
                            {['home', 'calculator', 'contact', 'admin'].map(p => (
                                <button key={p} onClick={() => go(p)} className="hover:text-brand-400 capitalize transition-colors">{p}</button>
                            ))}
                        </div>
                        <div className="text-surface-600 text-xs">
                            © 2026 Kannan Kalyani. All rights reserved.<br />
                            <span className="text-surface-700">Based in Kollam, Kerala</span>
                        </div>
                    </div>
                </footer>
            );
        }

        // ─── HOME PAGE ─────────────────────────────────────────────────────────────────
        function HomePage({ navigate }) {
            const services = [
                { icon: '🏗️', title: 'M-Sand & P-Sand', desc: 'High-quality manufactured & plastering sand for all construction needs.' },
                { icon: '⛏️', title: 'Crushed Metal', desc: 'Precisely graded crushed stone for concrete and road projects.' },
                { icon: '🪨', title: 'Rock Boulders', desc: 'Durable boulders for foundations, retaining walls and landscaping.' },
                { icon: '🔹', title: 'Gravel & Earth', desc: 'Natural gravel, cutting earth and quarry waste for filling & base layers.' },
                { icon: '🏚️', title: 'Building Demolition', desc: 'Safe and professional demolition with complete waste removal.' },
                { icon: '📋', title: 'Land Development', desc: 'End-to-end land development with full legal documentation support.' },
            ];
            const stats = [
                { value: '500+', label: 'Projects Delivered' },
                { value: '10+', label: 'Years Experience' },
                { value: '6', label: 'Service Zones' },
                { value: '24h', label: 'Response Time' },
            ];

            useEffect(() => {
                const timer = setTimeout(() => {
                    const el = document.getElementById('home-map');
                    if (!el || el._leaflet_id) return;
                    const map = L.map('home-map', { zoomControl: true, scrollWheelZoom: false }).setView([8.8932, 76.6141], 10);
                    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                        attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>', maxZoom: 18
                    }).addTo(map);
                    const mkIcon = L.divIcon({
                        className: '',
                        html: `<div style="background:linear-gradient(135deg,#FFC107,#FF8F00);width:28px;height:28px;border-radius:50% 50% 50% 0;transform:rotate(-45deg);border:3px solid rgba(255,255,255,.85);box-shadow:0 3px 12px rgba(255,193,7,.6)"></div>`,
                        iconSize: [28, 28], iconAnchor: [14, 28]
                    });
                    [
                        { name: 'Kollam (HQ)', lat: 8.8932, lng: 76.6141 },
                        { name: 'Kallada', lat: 8.9167, lng: 76.7667 },
                        { name: 'Munroe Thuruth', lat: 8.9833, lng: 76.5667 },
                        { name: 'Pavithreswaram', lat: 8.9422, lng: 76.6844 },
                        { name: 'West Kallada', lat: 8.9250, lng: 76.7100 },
                    ].forEach(a => L.marker([a.lat, a.lng], { icon: mkIcon }).addTo(map)
                        .bindPopup(`<b style="font-family:Inter,sans-serif;font-size:13px">${a.name}</b>`));
                }, 400);
                return () => clearTimeout(timer);
            }, []);

            return (
                <div className="pt-16">
                    {/* HERO */}
                    <section className="min-h-screen flex items-center relative overflow-hidden hero-bg dot-pattern">
                        <div style={{ position: 'absolute', top: '8%', right: '5%', width: '280px', height: '280px', background: 'rgba(255,193,7,.06)', borderRadius: '50%', filter: 'blur(60px)', pointerEvents: 'none' }} />
                        <div style={{ position: 'absolute', bottom: '10%', left: '4%', width: '360px', height: '360px', background: 'rgba(255,143,0,.04)', borderRadius: '50%', filter: 'blur(80px)', pointerEvents: 'none' }} />

                        <div className="max-w-6xl mx-auto px-4 py-20 w-full grid md:grid-cols-2 items-center gap-12">
                            {/* Left: text */}
                            <div className="animate-slide-in-left">
                                <div className="inline-flex items-center gap-2 mb-6 px-4 py-1.5 rounded-full" style={{ background: 'rgba(255,193,7,.1)', border: '1px solid rgba(255,193,7,.2)' }}>
                                    <span style={{ width: '8px', height: '8px', background: '#FFCA28', borderRadius: '50%', animation: 'pulseGlow 2s ease-in-out infinite', display: 'inline-block' }} />
                                    <span className="text-brand-400 text-xs font-semibold tracking-widest uppercase">Kollam's Trusted Logistics</span>
                                </div>

                                <h1 className="font-display font-black leading-none mb-4" style={{ fontSize: 'clamp(2.8rem,7vw,5rem)' }}>
                                    <span className="text-white">KANNAN</span><br />
                                    <span className="gradient-text">KALYANI</span>
                                </h1>
                                <p className="text-surface-400 text-lg mb-2 font-medium">Construction Logistics &amp; Services</p>
                                <p className="text-brand-500 italic text-base mb-8 font-medium">"Unmatched load. On-time delivery."</p>
                                <p className="text-surface-300 text-sm leading-relaxed mb-10 max-w-md">
                                    Reliable delivery of M-Sand, P-Sand, Crushed Metal, Rock Boulders, Gravel and more —
                                    serving Kollam, Kallada, Munroe Thuruth and surrounding areas.
                                </p>
                                <div className="flex flex-wrap gap-3">
                                    <button onClick={() => navigate('calculator')} className="btn-primary">
                                        🧮 Calculate Estimate
                                    </button>
                                    <button onClick={() => navigate('contact')} className="btn-secondary">
                                        📞 Contact Us
                                    </button>
                                </div>
                            </div>

                            {/* Right: image */}
                            <div className="animate-slide-in-right">
                                <div className="glass-card rounded-2xl overflow-hidden animate-float" style={{ border: '1px solid rgba(255,255,255,.07)' }}>
                                    <img src="images/6779.png" alt="Kannan Kalyani Truck"
                                        style={{ width: '100%', maxHeight: '400px', objectFit: 'cover', objectPosition: 'center', display: 'block' }}
                                        onError={e => { e.target.parentNode.innerHTML = '<div style="height:300px;display:flex;align-items:center;justify-content:center;font-size:5rem">🚛</div>' }}
                                    />
                                </div>
                                <div className="mt-3 flex gap-2">
                                    {['✅ Licensed', '📍 Kollam Based', '⚡ Fast Delivery'].map(b => (
                                        <div key={b} className="glass rounded-xl px-3 py-2 text-xs text-surface-300 font-medium flex-1 text-center">{b}</div>
                                    ))}
                                </div>
                            </div>
                        </div>
                    </section>

                    {/* STATS */}
                    <section className="py-14" style={{ borderTop: '1px solid rgba(255,255,255,.05)', borderBottom: '1px solid rgba(255,255,255,.05)' }}>
                        <div className="max-w-6xl mx-auto px-4 grid grid-cols-2 md:grid-cols-4 gap-4">
                            {stats.map((s, i) => (
                                <div key={i} className={`glass-card rounded-2xl p-6 text-center animate-scale-in stagger-${i + 1}`}>
                                    <div className="gradient-text font-display font-black text-4xl mb-1">{s.value}</div>
                                    <div className="text-surface-400 text-xs font-medium">{s.label}</div>
                                </div>
                            ))}
                        </div>
                    </section>

                    {/* SERVICES */}
                    <section className="py-20 px-4">
                        <div className="max-w-6xl mx-auto">
                            <div className="text-center mb-12">
                                <p className="text-brand-400 text-xs font-semibold uppercase tracking-widest mb-3">What We Offer</p>
                                <h2 className="font-display font-black text-3xl md:text-4xl text-white mb-3">Our Services</h2>
                                <p className="text-surface-400 text-sm max-w-sm mx-auto">Comprehensive construction logistics, material delivery and land development across Kollam.</p>
                            </div>
                            <div className="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
                                {services.map((s, i) => (
                                    <div key={i} className={`glass-card rounded-2xl p-6 animate-slide-up stagger-${i + 1}`}>
                                        <div className="text-3xl mb-4">{s.icon}</div>
                                        <h3 className="text-white font-bold text-sm mb-2">{s.title}</h3>
                                        <p className="text-surface-400 text-sm leading-relaxed">{s.desc}</p>
                                    </div>
                                ))}
                            </div>
                        </div>
                    </section>

                    {/* MAP */}
                    <section className="py-16 px-4">
                        <div className="max-w-6xl mx-auto">
                            <div className="text-center mb-10">
                                <p className="text-brand-400 text-xs font-semibold uppercase tracking-widest mb-3">Coverage</p>
                                <h2 className="font-display font-black text-3xl text-white mb-3">Service Area</h2>
                                <p className="text-surface-400 text-sm">Based in Kollam — serving all marked zones with reliable delivery.</p>
                            </div>
                            <div className="map-wrap" style={{ height: '400px' }}>
                                <div id="home-map" style={{ width: '100%', height: '100%' }} />
                            </div>
                        </div>
                    </section>

                    {/* CTA */}
                    <section className="py-14 px-4">
                        <div className="max-w-2xl mx-auto">
                            <div className="glass-card rounded-3xl p-10 text-center animate-pulse-glow" style={{ border: '1px solid rgba(255,193,7,.1)' }}>
                                <div className="text-5xl mb-4">🚛</div>
                                <h2 className="font-display font-black text-2xl md:text-3xl text-white mb-3">Ready to Place an Order?</h2>
                                <p className="text-surface-400 text-sm mb-7 max-w-sm mx-auto">Use our smart calculator for an instant cost estimate, or call us directly.</p>
                                <button onClick={() => navigate('calculator')} className="btn-primary">
                                    Calculate My Estimate →
                                </button>
                            </div>
                        </div>
                    </section>
                </div>
            );
        }

        // ─── CALCULATOR ────────────────────────────────────────────────────────────────
        function CalculatorPage() {
            const [materials, setMaterials] = useState([]);
            const [locations, setLocations] = useState([]);
            const [matId, setMatId] = useState('');
            const [ft, setFt] = useState(FT_OPTIONS[0]);
            const [loads, setLoads] = useState(1);
            const [locId, setLocId] = useState('');
            const [result, setResult] = useState(null);
            const [busy, setBusy] = useState(false);
            const resultRef = useRef(null);

            useEffect(() => {
                const m = getMaterials(); const l = getLocations();
                setMaterials(m); setLocations(l);
                setMatId(String(m[0]?.id ?? '')); setLocId(String(l[0]?.id ?? ''));
            }, []);

            const mat = materials.find(m => m.id === parseInt(matId));
            const loc = locations.find(l => l.id === parseInt(locId));
            const isPerFt = mat?.pricing_type === 'per_ft';

            function calculate(e) {
                e.preventDefault();
                if (!mat || !loc) return;
                setBusy(true);
                setTimeout(() => {
                    const materialCost = isPerFt ? mat.price_per_ft * ft : mat.price_per_load;
                    const transportCost = loc.transport_rate;
                    const baseCost = materialCost + transportCost;
                    const totalCost = baseCost * loads;
                    setResult({ materialCost, transportCost, baseCost, totalCost, loads, mat, loc, ft });
                    setBusy(false);
                    setTimeout(() => resultRef.current?.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 120);
                }, 700);
            }

            return (
                <div className="pt-24 pb-16 px-4 min-h-screen">
                    <div className="max-w-xl mx-auto">
                        {/* Header */}
                        <div className="text-center mb-10 animate-slide-up">
                            <div className="inline-flex items-center gap-2 px-4 py-1.5 rounded-full mb-4" style={{ background: 'rgba(255,193,7,.1)', border: '1px solid rgba(255,193,7,.2)' }}>
                                <span className="text-brand-400 text-xs font-semibold tracking-widest uppercase">Smart Pricing Engine</span>
                            </div>
                            <h1 className="font-display font-black text-3xl md:text-4xl text-white mb-2">Expense Calculator</h1>
                            <p className="text-surface-400 text-sm">Get an instant cost estimate for your delivery.</p>
                        </div>

                        {/* Form */}
                        <div className="glass-card rounded-3xl p-6 md:p-8 animate-scale-in" style={{ border: '1px solid rgba(255,255,255,.07)' }}>
                            <form onSubmit={calculate} className="space-y-6">

                                {/* Material select */}
                                <div>
                                    <label className="form-label">Material Type</label>
                                    <div style={{ position: 'relative' }}>
                                        <select className="form-input" style={{ paddingRight: '40px' }} value={matId} onChange={e => setMatId(e.target.value)} required>
                                            {materials.map(m => (
                                                <option key={m.id} value={m.id}>
                                                    {m.icon} {m.name} — {m.pricing_type === 'per_ft' ? `₹${m.price_per_ft}/ft` : `₹${m.price_per_load?.toLocaleString('en-IN')}/load`}
                                                </option>
                                            ))}
                                        </select>
                                        <span style={{ position: 'absolute', right: '14px', top: '50%', transform: 'translateY(-50%)', color: '#9E9E9E', pointerEvents: 'none' }}>▾</span>
                                    </div>
                                    {mat && <p className="mt-1.5 text-xs text-surface-500">{mat.description}</p>}
                                </div>

                                {/* Pricing type badge */}
                                {mat && (
                                    <div className="rounded-xl p-3" style={{
                                        background: isPerFt ? 'rgba(59,130,246,.08)' : 'rgba(168,85,247,.08)',
                                        border: isPerFt ? '1px solid rgba(59,130,246,.2)' : '1px solid rgba(168,85,247,.2)',
                                        color: isPerFt ? '#93C5FD' : '#C4B5FD',
                                        fontSize: '12px', fontWeight: 600, display: 'flex', alignItems: 'center', gap: '8px'
                                    }}>
                                        <span>{isPerFt ? '📐' : '📦'}</span>
                                        {isPerFt
                                            ? `Type A — Per Foot: ₹${mat.price_per_ft} × selected ft × loads`
                                            : `Type B — Fixed Load: ₹${mat.price_per_load?.toLocaleString('en-IN')} per load`
                                        }
                                    </div>
                                )}

                                {/* Ft selector — only per_ft */}
                                {isPerFt && (
                                    <div>
                                        <label className="form-label">Measurement (cubic feet)</label>
                                        <div className="grid grid-cols-5 gap-2">
                                            {FT_OPTIONS.map(f => (
                                                <button key={f} type="button" onClick={() => setFt(f)}
                                                    className="py-3 rounded-xl text-sm font-bold transition-all"
                                                    style={{
                                                        background: ft === f ? 'rgba(255,193,7,.2)' : 'rgba(255,255,255,.04)',
                                                        border: ft === f ? '1px solid rgba(255,193,7,.45)' : '1px solid rgba(255,255,255,.07)',
                                                        color: ft === f ? '#FFCA28' : '#9E9E9E',
                                                        boxShadow: ft === f ? '0 4px 14px rgba(255,193,7,.15)' : 'none'
                                                    }}
                                                >{f}</button>
                                            ))}
                                        </div>
                                    </div>
                                )}

                                {/* Loads */}
                                <div>
                                    <label className="form-label">Number of Loads</label>
                                    <div className="flex items-center gap-3">
                                        <button type="button" onClick={() => setLoads(l => Math.max(1, l - 1))}
                                            className="glass rounded-xl text-xl font-bold hover:bg-white/10 transition-colors"
                                            style={{ width: '46px', height: '46px', border: '1px solid rgba(255,255,255,.1)', flexShrink: 0, display: 'flex', alignItems: 'center', justifyContent: 'center', color: '#E0E0E0' }}
                                        >−</button>
                                        <input type="number" className="form-input text-center text-xl font-bold" style={{ color: '#FFCA28' }}
                                            value={loads} min="1" max="100"
                                            onChange={e => setLoads(Math.max(1, parseInt(e.target.value) || 1))} required
                                        />
                                        <button type="button" onClick={() => setLoads(l => Math.min(100, l + 1))}
                                            className="glass rounded-xl text-xl font-bold hover:bg-white/10 transition-colors"
                                            style={{ width: '46px', height: '46px', border: '1px solid rgba(255,255,255,.1)', flexShrink: 0, display: 'flex', alignItems: 'center', justifyContent: 'center', color: '#E0E0E0' }}
                                        >+</button>
                                    </div>
                                </div>

                                {/* Location */}
                                <div>
                                    <label className="form-label">Delivery Location</label>
                                    <div style={{ position: 'relative' }}>
                                        <select className="form-input" style={{ paddingRight: '40px' }} value={locId} onChange={e => setLocId(e.target.value)} required>
                                            {locations.map(l => (
                                                <option key={l.id} value={l.id}>
                                                    📍 {l.name} — ₹{l.transport_rate.toLocaleString('en-IN')} transport
                                                </option>
                                            ))}
                                        </select>
                                        <span style={{ position: 'absolute', right: '14px', top: '50%', transform: 'translateY(-50%)', color: '#9E9E9E', pointerEvents: 'none' }}>▾</span>
                                    </div>
                                    {loc && <p className="mt-1.5 text-xs text-surface-500">~{loc.distance_km} km from Kollam HQ</p>}
                                </div>

                                {/* Submit */}
                                <button type="submit" disabled={busy} className="btn-primary w-full justify-center" style={{ width: '100%' }}>
                                    {busy ? <><span className="spinner" />Calculating…</> : '🧮 Calculate Total Cost'}
                                </button>
                            </form>
                        </div>

                        {/* RESULT */}
                        {result && (
                            <div ref={resultRef} className="mt-7 glass-card rounded-3xl overflow-hidden animate-scale-in" style={{ border: '1px solid rgba(255,193,7,.12)' }}>
                                {/* Shimmer header */}
                                <div className="result-shimmer px-6 py-5" style={{ borderBottom: '1px solid rgba(255,255,255,.05)' }}>
                                    <div className="flex items-center justify-between">
                                        <h2 className="text-white font-bold text-sm">Cost Breakdown</h2>
                                        <button onClick={() => setResult(null)} className="text-surface-500 hover:text-white text-xs transition-colors">✕ Clear</button>
                                    </div>
                                    <p className="text-surface-400 text-xs mt-1">{result.mat.icon} {result.mat.name} → 📍 {result.loc.name}</p>
                                </div>

                                {/* Rows */}
                                <div className="px-6 py-5 space-y-4">
                                    {[
                                        {
                                            label: 'Material Cost',
                                            sub: result.mat.pricing_type === 'per_ft' ? `₹${result.mat.price_per_ft}/ft × ${result.ft} ft` : 'Fixed price per load',
                                            val: `₹${result.materialCost.toLocaleString('en-IN')}`
                                        },
                                        { label: 'Transport Cost', sub: `📍 ${result.loc.name}`, val: `₹${result.transportCost.toLocaleString('en-IN')}` },
                                        { label: 'Base Cost (per load)', sub: 'Material + Transport', val: `₹${result.baseCost.toLocaleString('en-IN')}` },
                                    ].map((r, i) => (
                                        <div key={i}>
                                            {i > 0 && <div style={{ borderTop: '1px solid rgba(255,255,255,.05)', marginBottom: '16px' }} />}
                                            <div className="flex items-center justify-between">
                                                <div>
                                                    <div className="text-surface-300 text-sm font-medium">{r.label}</div>
                                                    <div className="text-surface-500 text-xs mt-0.5">{r.sub}</div>
                                                </div>
                                                <div className="text-white font-bold text-sm">{r.val}</div>
                                            </div>
                                        </div>
                                    ))}
                                    {result.loads > 1 && (
                                        <div style={{ borderTop: '1px solid rgba(255,255,255,.05)', paddingTop: '12px' }}>
                                            <div className="flex justify-between text-surface-500 text-xs">
                                                <span>× {result.loads} loads</span>
                                                <span>₹{result.baseCost.toLocaleString('en-IN')} × {result.loads}</span>
                                            </div>
                                        </div>
                                    )}
                                </div>

                                {/* Total */}
                                <div className="px-6 py-5" style={{ borderTop: '1px solid rgba(255,193,7,.12)', background: 'rgba(255,193,7,.04)' }}>
                                    <div className="flex items-center justify-between">
                                        <div>
                                            <div className="text-brand-400 text-xs font-semibold uppercase tracking-wider">Total Cost</div>
                                            <div className="text-surface-500 text-xs mt-0.5">{result.loads} load{result.loads > 1 ? 's' : ''}</div>
                                        </div>
                                        <div className="gradient-text font-display font-black text-3xl count-animate">
                                            ₹{result.totalCost.toLocaleString('en-IN')}
                                        </div>
                                    </div>
                                </div>

                                {/* Disclaimer */}
                                <div className="px-6 py-3" style={{ background: 'rgba(0,0,0,.2)' }}>
                                    <p className="text-surface-600 text-xs text-center">
                                        ⚠️ Approximate estimate. Actual cost may vary based on site conditions and availability.
                                    </p>
                                </div>
                            </div>
                        )}
                    </div>
                </div>
            );
        }

        // ─── ADMIN PAGE ────────────────────────────────────────────────────────────────
        function MatEditRow({ mat, setMat, onSave, onCancel }) {
            return (
                <tr style={{ background: 'rgba(255,193,7,.04)' }}>
                    <td colSpan={4} style={{ padding: '16px' }}>
                        <div className="grid gap-3" style={{ gridTemplateColumns: '1fr 1fr 1fr auto' }}>
                            <div>
                                <label className="form-label">Name</label>
                                <input className="form-input" style={{ padding: '10px 12px', fontSize: '13px' }} value={mat.name} onChange={e => setMat({ ...mat, name: e.target.value })} />
                            </div>
                            <div>
                                <label className="form-label">Type</label>
                                <select className="form-input" style={{ padding: '10px 12px', fontSize: '13px' }} value={mat.pricing_type}
                                    onChange={e => setMat({ ...mat, pricing_type: e.target.value, price_per_ft: null, price_per_load: null })}>
                                    <option value="per_ft">Per Foot</option>
                                    <option value="per_load">Per Load</option>
                                </select>
                            </div>
                            <div>
                                <label className="form-label">{mat.pricing_type === 'per_ft' ? 'Price/ft (₹)' : 'Price/load (₹)'}</label>
                                <input className="form-input" style={{ padding: '10px 12px', fontSize: '13px' }} type="number"
                                    value={mat.pricing_type === 'per_ft' ? mat.price_per_ft || '' : mat.price_per_load || ''}
                                    onChange={e => { const v = parseFloat(e.target.value); setMat(mat.pricing_type === 'per_ft' ? { ...mat, price_per_ft: v, price_per_load: null } : { ...mat, price_per_load: v, price_per_ft: null }); }}
                                />
                            </div>
                            <div className="flex gap-2 items-end">
                                <button onClick={() => onSave(mat)} className="btn-primary" style={{ padding: '10px 16px', fontSize: '13px' }}>Save</button>
                                <button onClick={onCancel} className="btn-secondary" style={{ padding: '10px 16px', fontSize: '13px' }}>Cancel</button>
                            </div>
                        </div>
                    </td>
                </tr>
            );
        }
        function LocEditRow({ loc, setLoc, onSave, onCancel }) {
            return (
                <tr style={{ background: 'rgba(255,193,7,.04)' }}>
                    <td colSpan={4} style={{ padding: '16px' }}>
                        <div className="grid gap-3" style={{ gridTemplateColumns: '1fr 1fr 1fr auto' }}>
                            <div>
                                <label className="form-label">Name</label>
                                <input className="form-input" style={{ padding: '10px 12px', fontSize: '13px' }} value={loc.name} onChange={e => setLoc({ ...loc, name: e.target.value })} />
                            </div>
                            <div>
                                <label className="form-label">Distance (km)</label>
                                <input className="form-input" style={{ padding: '10px 12px', fontSize: '13px' }} type="number" value={loc.distance_km} onChange={e => setLoc({ ...loc, distance_km: parseFloat(e.target.value) })} />
                            </div>
                            <div>
                                <label className="form-label">Transport Rate (₹)</label>
                                <input className="form-input" style={{ padding: '10px 12px', fontSize: '13px' }} type="number" value={loc.transport_rate} onChange={e => setLoc({ ...loc, transport_rate: parseFloat(e.target.value) })} />
                            </div>
                            <div className="flex gap-2 items-end">
                                <button onClick={() => onSave(loc)} className="btn-primary" style={{ padding: '10px 16px', fontSize: '13px' }}>Save</button>
                                <button onClick={onCancel} className="btn-secondary" style={{ padding: '10px 16px', fontSize: '13px' }}>Cancel</button>
                            </div>
                        </div>
                    </td>
                </tr>
            );
        }

        function AdminPage() {
            const [tab, setTab] = useState('materials');
            const [materials, setMaterials] = useState([]);
            const [locations, setLocations] = useState([]);
            const [toast, setToast] = useState(null);
            const [editingMat, setEditingMat] = useState(null);
            const [editingLoc, setEditingLoc] = useState(null);
            const [newMat, setNewMat] = useState({ name: '', pricing_type: 'per_ft', price_per_ft: '', price_per_load: '', description: '', icon: '📦' });
            const [newLoc, setNewLoc] = useState({ name: '', transport_rate: '', distance_km: '' });

            useEffect(() => { setMaterials(getMaterials()); setLocations(getLocations()); }, []);

            const notify = (msg, type = 'success') => setToast({ msg, type });

            function onSaveMat(m) {
                const u = materials.map(x => x.id === m.id ? m : x); saveMaterials(u); setMaterials(u); setEditingMat(null); notify('Material updated!');
            }
            function onDelMat(id) {
                if (!confirm('Delete this material?')) return;
                const u = materials.filter(m => m.id !== id); saveMaterials(u); setMaterials(u); notify('Deleted.', 'error');
            }
            function onAddMat(e) {
                e.preventDefault();
                const m = {
                    id: Date.now(), name: newMat.name, pricing_type: newMat.pricing_type,
                    price_per_ft: newMat.pricing_type === 'per_ft' ? parseFloat(newMat.price_per_ft) : null,
                    price_per_load: newMat.pricing_type === 'per_load' ? parseFloat(newMat.price_per_load) : null,
                    description: newMat.description, icon: newMat.icon || '📦'
                };
                const u = [...materials, m]; saveMaterials(u); setMaterials(u);
                setNewMat({ name: '', pricing_type: 'per_ft', price_per_ft: '', price_per_load: '', description: '', icon: '📦' });
                notify('Material added!');
            }

            function onSaveLoc(l) {
                const u = locations.map(x => x.id === l.id ? l : x); saveLocations(u); setLocations(u); setEditingLoc(null); notify('Location updated!');
            }
            function onDelLoc(id) {
                if (!confirm('Delete this location?')) return;
                const u = locations.filter(l => l.id !== id); saveLocations(u); setLocations(u); notify('Deleted.', 'error');
            }
            function onAddLoc(e) {
                e.preventDefault();
                const l = { id: Date.now(), name: newLoc.name, transport_rate: parseFloat(newLoc.transport_rate), distance_km: parseFloat(newLoc.distance_km) || 0 };
                const u = [...locations, l]; saveLocations(u); setLocations(u);
                setNewLoc({ name: '', transport_rate: '', distance_km: '' }); notify('Location added!');
            }

            function resetAll() {
                if (!confirm('Reset ALL data to factory defaults?')) return;
                localStorage.removeItem('kk_materials'); localStorage.removeItem('kk_locations');
                setMaterials(getMaterials()); setLocations(getLocations()); notify('Reset complete!');
            }

            const tabBtn = (id, label) => (
                <button key={id} onClick={() => setTab(id)}
                    className="flex-1 py-2.5 rounded-xl text-sm font-semibold capitalize transition-all"
                    style={{
                        background: tab === id ? 'linear-gradient(135deg,#FFC107,#FF8F00)' : 'transparent',
                        color: tab === id ? '#121212' : '#9E9E9E',
                        boxShadow: tab === id ? '0 4px 14px rgba(255,193,7,.25)' : 'none'
                    }}
                >{label}</button>
            );

            return (
                <div className="pt-24 pb-16 px-4 min-h-screen">
                    <div className="max-w-4xl mx-auto">
                        {/* Header */}
                        <div className="flex items-start justify-between flex-wrap gap-4 mb-8 animate-slide-up">
                            <div>
                                <p className="text-brand-400 text-xs font-semibold uppercase tracking-widest mb-1">Admin Panel</p>
                                <h1 className="font-display font-black text-3xl text-white">Pricing Control</h1>
                                <p className="text-surface-400 text-sm mt-1">Manage material prices and delivery location rates.</p>
                            </div>
                            <button onClick={resetAll} className="btn-secondary" style={{ padding: '10px 18px', fontSize: '13px' }}>🔄 Reset Defaults</button>
                        </div>

                        {/* Tabs */}
                        <div className="flex gap-2 mb-6 p-1.5 rounded-2xl" style={{ background: 'rgba(255,255,255,.03)', border: '1px solid rgba(255,255,255,.06)' }}>
                            {tabBtn('materials', '🧱 Materials')}
                            {tabBtn('locations', '📍 Locations')}
                        </div>

                        {/* ── Materials Tab ── */}
                        {tab === 'materials' && (
                            <div className="space-y-5 animate-fade-in">
                                <div className="glass-card rounded-2xl overflow-hidden" style={{ border: '1px solid rgba(255,255,255,.06)' }}>
                                    <div className="px-5 py-4" style={{ borderBottom: '1px solid rgba(255,255,255,.05)' }}>
                                        <span className="text-white font-bold text-sm">📋 Material Catalog ({materials.length} items)</span>
                                    </div>
                                    <div style={{ overflowX: 'auto' }}>
                                        <table className="admin-table">
                                            <thead><tr>
                                                <th>Material</th><th>Pricing Type</th><th>Rate</th><th style={{ textAlign: 'right' }}>Actions</th>
                                            </tr></thead>
                                            <tbody>
                                                {materials.map(m => editingMat?.id === m.id ? (
                                                    <MatEditRow key={m.id} mat={editingMat} setMat={setEditingMat} onSave={onSaveMat} onCancel={() => setEditingMat(null)} />
                                                ) : (
                                                    <tr key={m.id}>
                                                        <td>
                                                            <div className="flex items-center gap-2">
                                                                <span style={{ fontSize: '20px' }}>{m.icon}</span>
                                                                <div>
                                                                    <div className="text-white font-medium" style={{ fontSize: '13px' }}>{m.name}</div>
                                                                    <div className="text-surface-500" style={{ fontSize: '11px' }}>{m.description}</div>
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <span style={{
                                                                padding: '3px 8px', borderRadius: '6px', fontSize: '11px', fontWeight: 600,
                                                                background: m.pricing_type === 'per_ft' ? 'rgba(59,130,246,.1)' : 'rgba(168,85,247,.1)',
                                                                border: m.pricing_type === 'per_ft' ? '1px solid rgba(59,130,246,.25)' : '1px solid rgba(168,85,247,.25)',
                                                                color: m.pricing_type === 'per_ft' ? '#93C5FD' : '#C4B5FD'
                                                            }}>
                                                                {m.pricing_type === 'per_ft' ? '📐 Per Foot' : '📦 Per Load'}
                                                            </span>
                                                        </td>
                                                        <td style={{ color: '#FFCA28', fontWeight: 700, fontSize: '13px' }}>
                                                            {m.pricing_type === 'per_ft' ? `₹${m.price_per_ft}/ft` : `₹${m.price_per_load?.toLocaleString('en-IN')}/load`}
                                                        </td>
                                                        <td style={{ textAlign: 'right' }}>
                                                            <div className="flex items-center justify-end gap-2">
                                                                <button onClick={() => setEditingMat({ ...m })} style={{ fontSize: '12px', padding: '5px 12px', borderRadius: '8px', background: 'rgba(255,255,255,.05)', border: '1px solid rgba(255,255,255,.1)', color: '#E0E0E0', cursor: 'pointer', fontFamily: 'Inter,sans-serif' }}>Edit</button>
                                                                <button onClick={() => onDelMat(m.id)} style={{ fontSize: '12px', padding: '5px 12px', borderRadius: '8px', background: 'rgba(239,68,68,.08)', border: '1px solid rgba(239,68,68,.2)', color: '#FCA5A5', cursor: 'pointer', fontFamily: 'Inter,sans-serif' }}>Delete</button>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                ))}
                                            </tbody>
                                        </table>
                                    </div>
                                </div>

                                {/* Add form */}
                                <div className="glass-card rounded-2xl p-6" style={{ border: '1px solid rgba(255,255,255,.06)' }}>
                                    <h3 className="text-white font-bold text-sm mb-4">➕ Add New Material</h3>
                                    <form onSubmit={onAddMat} className="grid gap-4" style={{ gridTemplateColumns: 'repeat(auto-fit,minmax(180px,1fr))' }}>
                                        <div>
                                            <label className="form-label">Name</label>
                                            <input className="form-input" placeholder="River Sand" value={newMat.name} onChange={e => setNewMat({ ...newMat, name: e.target.value })} required />
                                        </div>
                                        <div>
                                            <label className="form-label">Icon (emoji)</label>
                                            <input className="form-input" placeholder="📦" value={newMat.icon} onChange={e => setNewMat({ ...newMat, icon: e.target.value })} />
                                        </div>
                                        <div>
                                            <label className="form-label">Pricing Type</label>
                                            <select className="form-input" value={newMat.pricing_type} onChange={e => setNewMat({ ...newMat, pricing_type: e.target.value })}>
                                                <option value="per_ft">Per Foot (Type A)</option>
                                                <option value="per_load">Per Load (Type B)</option>
                                            </select>
                                        </div>
                                        <div>
                                            {newMat.pricing_type === 'per_ft' ? <>
                                                <label className="form-label">Price/ft (₹)</label>
                                                <input className="form-input" type="number" placeholder="50" value={newMat.price_per_ft} onChange={e => setNewMat({ ...newMat, price_per_ft: e.target.value })} required />
                                            </> : <>
                                                <label className="form-label">Price/load (₹)</label>
                                                <input className="form-input" type="number" placeholder="3000" value={newMat.price_per_load} onChange={e => setNewMat({ ...newMat, price_per_load: e.target.value })} required />
                                            </>}
                                        </div>
                                        <div style={{ gridColumn: '1 / -1' }}>
                                            <label className="form-label">Description</label>
                                            <input className="form-input" placeholder="Short description" value={newMat.description} onChange={e => setNewMat({ ...newMat, description: e.target.value })} />
                                        </div>
                                        <div style={{ gridColumn: '1 / -1' }}>
                                            <button type="submit" className="btn-primary" style={{ width: '100%', justifyContent: 'center' }}>➕ Add Material</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        )}

                        {/* ── Locations Tab ── */}
                        {tab === 'locations' && (
                            <div className="space-y-5 animate-fade-in">
                                <div className="glass-card rounded-2xl overflow-hidden" style={{ border: '1px solid rgba(255,255,255,.06)' }}>
                                    <div className="px-5 py-4" style={{ borderBottom: '1px solid rgba(255,255,255,.05)' }}>
                                        <span className="text-white font-bold text-sm">📍 Delivery Locations ({locations.length})</span>
                                    </div>
                                    <table className="admin-table">
                                        <thead><tr>
                                            <th>Location</th><th>Distance</th><th>Transport Rate</th><th style={{ textAlign: 'right' }}>Actions</th>
                                        </tr></thead>
                                        <tbody>
                                            {locations.map(l => editingLoc?.id === l.id ? (
                                                <LocEditRow key={l.id} loc={editingLoc} setLoc={setEditingLoc} onSave={onSaveLoc} onCancel={() => setEditingLoc(null)} />
                                            ) : (
                                                <tr key={l.id}>
                                                    <td className="text-white font-medium" style={{ fontSize: '13px' }}>📍 {l.name}</td>
                                                    <td className="text-surface-400" style={{ fontSize: '13px' }}>~{l.distance_km} km</td>
                                                    <td style={{ color: '#FFCA28', fontWeight: 700, fontSize: '13px' }}>₹{l.transport_rate.toLocaleString('en-IN')}</td>
                                                    <td style={{ textAlign: 'right' }}>
                                                        <div className="flex items-center justify-end gap-2">
                                                            <button onClick={() => setEditingLoc({ ...l })} style={{ fontSize: '12px', padding: '5px 12px', borderRadius: '8px', background: 'rgba(255,255,255,.05)', border: '1px solid rgba(255,255,255,.1)', color: '#E0E0E0', cursor: 'pointer', fontFamily: 'Inter,sans-serif' }}>Edit</button>
                                                            <button onClick={() => onDelLoc(l.id)} style={{ fontSize: '12px', padding: '5px 12px', borderRadius: '8px', background: 'rgba(239,68,68,.08)', border: '1px solid rgba(239,68,68,.2)', color: '#FCA5A5', cursor: 'pointer', fontFamily: 'Inter,sans-serif' }}>Delete</button>
                                                        </div>
                                                    </td>
                                                </tr>
                                            ))}
                                        </tbody>
                                    </table>
                                </div>

                                <div className="glass-card rounded-2xl p-6" style={{ border: '1px solid rgba(255,255,255,.06)' }}>
                                    <h3 className="text-white font-bold text-sm mb-4">➕ Add New Location</h3>
                                    <form onSubmit={onAddLoc} className="grid gap-4" style={{ gridTemplateColumns: '1fr 1fr 1fr' }}>
                                        <div>
                                            <label className="form-label">Location Name</label>
                                            <input className="form-input" placeholder="Munroturuthu" value={newLoc.name} onChange={e => setNewLoc({ ...newLoc, name: e.target.value })} required />
                                        </div>
                                        <div>
                                            <label className="form-label">Transport Rate (₹)</label>
                                            <input className="form-input" type="number" placeholder="2500" value={newLoc.transport_rate} onChange={e => setNewLoc({ ...newLoc, transport_rate: e.target.value })} required />
                                        </div>
                                        <div>
                                            <label className="form-label">Distance (km)</label>
                                            <input className="form-input" type="number" placeholder="20" value={newLoc.distance_km} onChange={e => setNewLoc({ ...newLoc, distance_km: e.target.value })} />
                                        </div>
                                        <div style={{ gridColumn: '1/-1' }}>
                                            <button type="submit" className="btn-primary" style={{ width: '100%', justifyContent: 'center' }}>➕ Add Location</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        )}
                    </div>
                    {toast && <Toast message={toast.msg} type={toast.type} onClose={() => setToast(null)} />}
                </div>
            );
        }

        // ─── CONTACT PAGE ──────────────────────────────────────────────────────────────
        function ContactPage() {
            const cards = [
                { icon: '📞', label: 'Phone', value: '+91 94470 XXXXX', hint: 'Mon–Sat, 8am–7pm' },
                { icon: '💬', label: 'WhatsApp', value: '+91 94470 XXXXX', hint: 'Fast response guaranteed' },
                { icon: '📍', label: 'Location', value: 'Kollam, Kerala', hint: 'Serving all nearby zones' },
                { icon: '✉️', label: 'Email', value: 'kannankalyani@gmail.com', hint: 'For quotes & enquiries' },
            ];
            return (
                <div className="pt-24 pb-16 px-4 min-h-screen">
                    <div className="max-w-3xl mx-auto">
                        <div className="text-center mb-12 animate-slide-up">
                            <p className="text-brand-400 text-xs font-semibold uppercase tracking-widest mb-3">Reach Us</p>
                            <h1 className="font-display font-black text-3xl md:text-4xl text-white mb-3">Contact Info</h1>
                            <p className="text-surface-400 text-sm">Based in Kollam and ready to serve your logistics needs.</p>
                        </div>

                        <div className="grid sm:grid-cols-2 gap-4 mb-8">
                            {cards.map((c, i) => (
                                <div key={i} className={`glass-card rounded-2xl p-6 animate-slide-up stagger-${i + 1}`}>
                                    <div style={{ fontSize: '2rem', marginBottom: '12px' }}>{c.icon}</div>
                                    <div className="text-surface-500 text-xs font-semibold uppercase tracking-wider mb-1">{c.label}</div>
                                    <div className="text-white font-bold text-sm mb-1">{c.value}</div>
                                    <div className="text-surface-500 text-xs">{c.hint}</div>
                                </div>
                            ))}
                        </div>

                        <div className="glass-card rounded-2xl p-7 mb-4" style={{ border: '1px solid rgba(255,255,255,.06)' }}>
                            <h2 className="text-white font-bold text-sm mb-5">🕐 Business Hours</h2>
                            {[
                                { day: 'Monday – Saturday', hours: '8:00 AM – 7:00 PM' },
                                { day: 'Sunday', hours: 'Emergency only' },
                                { day: 'Public Holidays', hours: 'Call ahead' },
                            ].map((r, i) => (
                                <div key={i} className="flex items-center justify-between py-3" style={{ borderBottom: i < 2 ? '1px solid rgba(255,255,255,.05)' : 'none' }}>
                                    <span className="text-surface-300 text-sm">{r.day}</span>
                                    <span className="text-sm font-semibold" style={{ color: r.hours.includes('Emergency') ? '#FFCA28' : '#fff' }}>{r.hours}</span>
                                </div>
                            ))}
                        </div>

                        <div className="glass-card rounded-2xl p-7" style={{ border: '1px solid rgba(255,255,255,.06)' }}>
                            <h2 className="text-white font-bold text-sm mb-4">🗺️ Service Zones</h2>
                            <div className="flex flex-wrap gap-2">
                                {['Kollam', 'Kallada', 'Munroe Thuruth', 'Pavithreswaram', 'West Kallada', 'Shuttle / Local'].map(z => (
                                    <span key={z} style={{ background: 'rgba(255,193,7,.08)', border: '1px solid rgba(255,193,7,.2)', color: '#FFD54F', fontSize: '12px', fontWeight: 500, padding: '5px 12px', borderRadius: '20px' }}>
                                        📍 {z}
                                    </span>
                                ))}
                            </div>
                        </div>
                    </div>
                </div>
            );
        }

        // ══════════════════════════════════════════════════════════════════════════════════
        // ─── LOGISTICS SYSTEM ─────────────────────────────────────────────────────────────
        // ══════════════════════════════════════════════════════════════════════════════════

        const LOAD_MATERIALS = ['Gravel', 'Cutting', 'Othala', 'Others'];

        // ── Data helpers ─────────────────────────────────────────────────────────────────
        function getSites() {
            try { const s = localStorage.getItem('kk_sites'); if (s) return JSON.parse(s); } catch (e) {}
            return [];
        }
        function saveSites(d) { localStorage.setItem('kk_sites', JSON.stringify(d)); }

        function getDefaultVehicles() {
            try { const s = localStorage.getItem('kk_def_vehicles'); if (s) return JSON.parse(s); } catch (e) {}
            return [];
        }
        function saveDefaultVehicles(d) { localStorage.setItem('kk_def_vehicles', JSON.stringify(d)); }

        function getLogKey(siteId, date) { return `kk_log_${siteId}_${date}`; }
        function getRawLog(siteId, date) {
            try { const s = localStorage.getItem(getLogKey(siteId, date)); if (s) return JSON.parse(s); } catch (e) {}
            return null;
        }
        function saveLog(siteId, date, data) { localStorage.setItem(getLogKey(siteId, date), JSON.stringify(data)); }

        // Build/merge a daily log with current default vehicles
        function buildLog(siteId, date) {
            const defs = getDefaultVehicles();
            const existing = getRawLog(siteId, date) || { owners: [] };

            // Group defaults by owner_name
            const defOwnerMap = {};
            defs.forEach(v => {
                if (!defOwnerMap[v.owner_name]) defOwnerMap[v.owner_name] = [];
                defOwnerMap[v.owner_name].push(v);
            });

            // For each default owner group, ensure it exists in the log
            Object.entries(defOwnerMap).forEach(([ownerName, vehicles]) => {
                let ownerEntry = existing.owners.find(o => o.is_default && o.name === ownerName);
                if (!ownerEntry) {
                    ownerEntry = { id: `downer_${ownerName}`, name: ownerName, contact: '', is_default: true, is_disabled: false, is_open: true, vehicles: [] };
                    existing.owners.unshift(ownerEntry);
                }
                vehicles.forEach(v => {
                    const dvId = `dv_${v.id}`;
                    if (!ownerEntry.vehicles.find(ev => ev.id === dvId)) {
                        ownerEntry.vehicles.push({ id: dvId, number: v.number, is_default: true, is_disabled: false, loads: [] });
                    }
                });
            });
            return existing;
        }

        // Collect all vehicle numbers in a log (for uniqueness check)
        function getAllVehicleNumbers(log) {
            const nums = [];
            (log.owners || []).forEach(o => (o.vehicles || []).forEach(v => nums.push(v.number.trim().toLowerCase())));
            return nums;
        }

        // Format date nicely
        function fmtDate(d) {
            if (!d) return '';
            const [y, m, day] = d.split('-');
            const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
            return `${parseInt(day)} ${months[parseInt(m)-1]} ${y}`;
        }

        // ── LoadEntryRow ─────────────────────────────────────────────────────────────────
        function LoadEntryRow({ load, onChange, onDelete }) {
            return (
                <div style={{ display:'flex', alignItems:'center', gap:'6px', padding:'8px 10px', borderRadius:'10px', background:'rgba(255,255,255,.03)', border:'1px solid rgba(255,255,255,.06)', marginBottom:'6px', flexWrap:'wrap' }}>
                    {/* Time */}
                    <input type="time" value={load.time}
                        onChange={e => onChange({ ...load, time: e.target.value })}
                        style={{ background:'rgba(255,255,255,.06)', border:'1px solid rgba(255,255,255,.1)', borderRadius:'8px', padding:'5px 8px', color:'#E0E0E0', fontSize:'12px', width:'92px', outline:'none', fontFamily:'Inter,sans-serif' }}
                    />
                    {/* Material */}
                    <select value={load.material} onChange={e => onChange({ ...load, material: e.target.value })}
                        style={{ flex:1, minWidth:'90px', background:'rgba(255,255,255,.06)', border:'1px solid rgba(255,255,255,.1)', borderRadius:'8px', padding:'5px 8px', color:'#E0E0E0', fontSize:'12px', outline:'none', fontFamily:'Inter,sans-serif' }}>
                        {LOAD_MATERIALS.map(m => <option key={m} value={m}>{m}</option>)}
                    </select>
                    {/* Payment toggle */}
                    <button onClick={() => onChange({ ...load, payment_status: load.payment_status === 'paid' ? 'unpaid' : 'paid' })}
                        style={{ padding:'5px 10px', borderRadius:'8px', fontSize:'11px', fontWeight:700, cursor:'pointer', whiteSpace:'nowrap', border:'none', fontFamily:'Inter,sans-serif',
                            background: load.payment_status === 'paid' ? 'rgba(34,197,94,.15)' : 'rgba(239,68,68,.12)',
                            color: load.payment_status === 'paid' ? '#86EFAC' : '#FCA5A5',
                            outline: load.payment_status === 'paid' ? '1px solid rgba(34,197,94,.3)' : '1px solid rgba(239,68,68,.25)'
                        }}>
                        {load.payment_status === 'paid' ? '✓ Paid' : '✗ Unpaid'}
                    </button>
                    {/* Pass checkbox */}
                    <label style={{ display:'flex', alignItems:'center', gap:'4px', fontSize:'11px', color: load.pass_given ? '#FFCA28' : '#9E9E9E', cursor:'pointer', whiteSpace:'nowrap', userSelect:'none' }}>
                        <input type="checkbox" checked={load.pass_given} onChange={e => onChange({ ...load, pass_given: e.target.checked })}
                            style={{ accentColor:'#FFC107', width:'13px', height:'13px' }} />
                        Pass
                    </label>
                    {/* Delete */}
                    <button onClick={onDelete} style={{ background:'none', border:'none', color:'#616161', cursor:'pointer', fontSize:'17px', lineHeight:1, padding:'2px 4px', borderRadius:'6px', transition:'color .2s' }}
                        onMouseOver={e=>e.target.style.color='#EF4444'} onMouseOut={e=>e.target.style.color='#616161'}
                    >×</button>
                </div>
            );
        }

        // ── VehicleCard ──────────────────────────────────────────────────────────────────
        function VehicleCard({ vehicle, onUpdate, onDelete }) {
            const [open, setOpen] = useState(false);

            function addLoad() {
                const now = new Date();
                const t = `${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
                const load = { id: Date.now(), time: t, material: LOAD_MATERIALS[0], payment_status: 'unpaid', pass_given: false };
                onUpdate({ ...vehicle, loads: [...vehicle.loads, load] });
                setOpen(true);
            }
            function updateLoad(idx, load) {
                const loads = [...vehicle.loads]; loads[idx] = load;
                onUpdate({ ...vehicle, loads });
            }
            function delLoad(idx) {
                onUpdate({ ...vehicle, loads: vehicle.loads.filter((_, i) => i !== idx) });
            }

            const paidCt   = vehicle.loads.filter(l => l.payment_status === 'paid').length;
            const unpaidCt = vehicle.loads.length - paidCt;
            const passCt   = vehicle.loads.filter(l => l.pass_given).length;
            const disabled = vehicle.is_disabled;

            return (
                <div style={{ border:'1px solid rgba(255,255,255,.07)', borderRadius:'12px', overflow:'hidden', marginBottom:'8px', opacity: disabled ? .45 : 1 }}>
                    {/* Vehicle header */}
                    <div style={{ display:'flex', alignItems:'center', gap:'8px', padding:'10px 14px', background:'rgba(255,255,255,.03)', cursor:'pointer' }}
                         onClick={() => !disabled && setOpen(o => !o)}>
                        {/* Default toggle */}
                        {vehicle.is_default && (
                            <button onClick={e => { e.stopPropagation(); onUpdate({ ...vehicle, is_disabled: !vehicle.is_disabled, loads: vehicle.loads }); }}
                                style={{ padding:'3px 8px', borderRadius:'6px', fontSize:'10px', fontWeight:700, cursor:'pointer', border:'none', fontFamily:'Inter,sans-serif',
                                    background: disabled ? 'rgba(255,255,255,.06)' : 'rgba(255,193,7,.15)',
                                    color: disabled ? '#616161' : '#FFCA28'
                                }}>{disabled ? 'OFF' : 'ON'}</button>
                        )}
                        <span style={{ fontWeight:700, fontSize:'13px', color: disabled ? '#616161' : '#fff' }}>🚛 {vehicle.number}</span>
                        {vehicle.is_default && <span style={{ fontSize:'10px', color:'#616161', fontStyle:'italic' }}>company</span>}
                        <div style={{ marginLeft:'auto', display:'flex', alignItems:'center', gap:'8px', flexShrink:0 }}>
                            {!disabled && <>
                                <span style={{ fontSize:'11px', color:'#757575' }}>{vehicle.loads.length} load{vehicle.loads.length !== 1 ? 's' : ''}</span>
                                {paidCt   > 0 && <span style={{ fontSize:'11px', color:'#86EFAC' }}>✓{paidCt}</span>}
                                {unpaidCt > 0 && <span style={{ fontSize:'11px', color:'#FCA5A5' }}>✗{unpaidCt}</span>}
                                {passCt   > 0 && <span style={{ fontSize:'11px', color:'#FFCA28' }}>🎫{passCt}</span>}
                            </>}
                            {!vehicle.is_default && (
                                <button onClick={e => { e.stopPropagation(); if(confirm('Remove this vehicle?')) onDelete(); }}
                                    style={{ background:'none', border:'none', color:'#424242', cursor:'pointer', fontSize:'15px', padding:'2px' }}
                                    onMouseOver={e=>e.target.style.color='#EF4444'} onMouseOut={e=>e.target.style.color='#424242'}>×</button>
                            )}
                            {!disabled && <span style={{ color:'#424242', fontSize:'12px' }}>{open ? '▲' : '▼'}</span>}
                        </div>
                    </div>
                    {/* Load entries */}
                    {open && !disabled && (
                        <div style={{ padding:'10px 14px', background:'rgba(0,0,0,.15)' }}>
                            {vehicle.loads.length === 0 && (
                                <div style={{ textAlign:'center', color:'#424242', fontSize:'12px', padding:'12px 0' }}>No loads yet — add the first one</div>
                            )}
                            {vehicle.loads.map((load, idx) => (
                                <LoadEntryRow key={load.id} load={load}
                                    onChange={l => updateLoad(idx, l)}
                                    onDelete={() => delLoad(idx)} />
                            ))}
                            <button onClick={addLoad}
                                style={{ marginTop:'6px', width:'100%', padding:'7px', borderRadius:'8px', fontSize:'12px', fontWeight:600, cursor:'pointer', border:'1px dashed rgba(255,193,7,.25)', background:'rgba(255,193,7,.04)', color:'#FFCA28', fontFamily:'Inter,sans-serif', transition:'all .2s' }}
                                onMouseOver={e=>e.currentTarget.style.background='rgba(255,193,7,.09)'}
                                onMouseOut={e=>e.currentTarget.style.background='rgba(255,193,7,.04)'}
                            >+ Add Load</button>
                        </div>
                    )}
                </div>
            );
        }

        // ── OwnerSection (accordion) ─────────────────────────────────────────────────────
        function OwnerSection({ owner, ownerIdx, log, onLogChange, onDelete }) {
            const [open, setOpen] = useState(owner.is_open !== false);
            const [addingVeh, setAddingVeh] = useState(false);
            const [newVehNum, setNewVehNum] = useState('');
            const [vehErr, setVehErr] = useState('');
            const [editingName, setEditingName] = useState(!owner.name);
            const [nameVal, setNameVal] = useState(owner.name);

            function updateOwner(updated) {
                const owners = [...log.owners]; owners[ownerIdx] = updated;
                onLogChange({ ...log, owners });
            }
            function updateVehicle(vIdx, updatedVeh) {
                const vehicles = [...owner.vehicles]; vehicles[vIdx] = updatedVeh;
                updateOwner({ ...owner, vehicles });
            }
            function deleteVehicle(vIdx) {
                updateOwner({ ...owner, vehicles: owner.vehicles.filter((_, i) => i !== vIdx) });
            }
            function saveName() {
                if (!nameVal.trim()) return;
                updateOwner({ ...owner, name: nameVal.trim() }); setEditingName(false);
            }
            function addVehicle(e) {
                e.preventDefault();
                const num = newVehNum.trim().toUpperCase();
                if (!num) { setVehErr('Enter vehicle number'); return; }
                const allNums = getAllVehicleNumbers(log);
                if (allNums.includes(num.toLowerCase())) { setVehErr('Vehicle number already exists in this day'); return; }
                const veh = { id: Date.now(), number: num, is_default: false, is_disabled: false, loads: [] };
                updateOwner({ ...owner, vehicles: [...owner.vehicles, veh] });
                setNewVehNum(''); setVehErr(''); setAddingVeh(false);
            }

            const disabled = owner.is_disabled;
            const totalLoads = owner.vehicles.filter(v => !v.is_disabled).reduce((s, v) => s + v.loads.length, 0);

            return (
                <div style={{ border:'1px solid rgba(255,255,255,.08)', borderRadius:'14px', marginBottom:'10px', overflow:'hidden' }}>
                    {/* Owner header */}
                    <div style={{ display:'flex', alignItems:'center', gap:'8px', padding:'12px 16px',
                        background: owner.is_default ? 'rgba(255,193,7,.05)' : 'rgba(255,255,255,.04)', cursor:'pointer',
                        borderBottom: open ? '1px solid rgba(255,255,255,.06)' : 'none' }}
                         onClick={() => setOpen(o => !o)}>
                        {/* Default toggle */}
                        {owner.is_default && (
                            <button onClick={e => { e.stopPropagation(); updateOwner({ ...owner, is_disabled: !owner.is_disabled }); }}
                                style={{ padding:'3px 8px', borderRadius:'6px', fontSize:'10px', fontWeight:700, cursor:'pointer', border:'none', fontFamily:'Inter,sans-serif',
                                    background: disabled ? 'rgba(255,255,255,.06)' : 'rgba(255,193,7,.15)',
                                    color: disabled ? '#616161' : '#FFCA28'
                                }}>{disabled ? 'OFF' : 'ON'}</button>
                        )}
                        {/* Owner name */}
                        <div style={{ flex:1 }}>
                            {editingName && !owner.is_default ? (
                                <div onClick={e => e.stopPropagation()} style={{ display:'flex', gap:'6px', alignItems:'center' }}>
                                    <input value={nameVal} onChange={e => setNameVal(e.target.value)}
                                        placeholder="Owner name" autoFocus
                                        onKeyDown={e => { if(e.key==='Enter') saveName(); }}
                                        style={{ flex:1, background:'rgba(255,255,255,.07)', border:'1px solid rgba(255,193,7,.4)', borderRadius:'8px', padding:'5px 10px', color:'#fff', fontSize:'13px', outline:'none', fontFamily:'Inter,sans-serif' }} />
                                    <button onClick={saveName} style={{ padding:'5px 12px', borderRadius:'8px', background:'linear-gradient(135deg,#FFC107,#FF8F00)', color:'#121212', fontSize:'12px', fontWeight:700, border:'none', cursor:'pointer', fontFamily:'Inter,sans-serif' }}>Save</button>
                                </div>
                            ) : (
                                <div style={{ display:'flex', alignItems:'center', gap:'6px' }}>
                                    <span style={{ fontWeight:700, fontSize:'14px', color: disabled ? '#616161' : '#fff' }}>
                                        {owner.is_default ? '🏢' : '👤'} {owner.name || <em style={{color:'#616161'}}>Unnamed Owner</em>}
                                    </span>
                                    {owner.is_default && <span style={{ fontSize:'10px', color:'#616161', fontStyle:'italic' }}>default</span>}
                                    {!owner.is_default && !editingName && (
                                        <button onClick={e => { e.stopPropagation(); setEditingName(true); setNameVal(owner.name); }}
                                            style={{ fontSize:'10px', color:'#424242', background:'none', border:'none', cursor:'pointer', padding:'2px 4px' }}
                                            onMouseOver={e=>e.target.style.color='#9E9E9E'} onMouseOut={e=>e.target.style.color='#424242'}>✎</button>
                                    )}
                                </div>
                            )}
                            {owner.contact && <div style={{ fontSize:'11px', color:'#616161', marginTop:'2px' }}>📞 {owner.contact}</div>}
                        </div>
                        {/* Stats + actions */}
                        <div style={{ display:'flex', alignItems:'center', gap:'8px', flexShrink:0 }}>
                            {!disabled && <span style={{ fontSize:'12px', color:'#757575' }}>{totalLoads} loads</span>}
                            {!owner.is_default && (
                                <button onClick={e => { e.stopPropagation(); if(confirm(`Remove owner "${owner.name}" and all their vehicles?`)) onDelete(); }}
                                    style={{ background:'none', border:'none', color:'#424242', cursor:'pointer', fontSize:'15px', padding:'2px 4px' }}
                                    onMouseOver={e=>e.target.style.color='#EF4444'} onMouseOut={e=>e.target.style.color='#424242'}>×</button>
                            )}
                            <span style={{ color:'#424242', fontSize:'13px' }}>{open ? '▲' : '▼'}</span>
                        </div>
                    </div>

                    {/* Owner body */}
                    {open && !disabled && (
                        <div style={{ padding:'12px 16px', background:'rgba(0,0,0,.08)' }}>
                            {/* Vehicles */}
                            {owner.vehicles.length === 0 && !addingVeh && (
                                <div style={{ color:'#424242', fontSize:'12px', textAlign:'center', padding:'10px 0 6px' }}>No vehicles — add one below</div>
                            )}
                            {owner.vehicles.map((veh, vIdx) => (
                                <VehicleCard key={veh.id} vehicle={veh}
                                    onUpdate={v => updateVehicle(vIdx, v)}
                                    onDelete={() => deleteVehicle(vIdx)} />
                            ))}

                            {/* Add vehicle inline form */}
                            {addingVeh ? (
                                <form onSubmit={addVehicle} style={{ display:'flex', gap:'6px', alignItems:'flex-start', marginTop:'8px' }}>
                                    <div style={{ flex:1 }}>
                                        <input value={newVehNum} onChange={e => { setNewVehNum(e.target.value); setVehErr(''); }}
                                            placeholder="Vehicle number (e.g. KL07 AB 1234)" autoFocus
                                            style={{ width:'100%', boxSizing:'border-box', background:'rgba(255,255,255,.06)', border: vehErr ? '1px solid rgba(239,68,68,.5)' : '1px solid rgba(255,255,255,.1)', borderRadius:'8px', padding:'8px 12px', color:'#fff', fontSize:'13px', outline:'none', fontFamily:'Inter,sans-serif' }} />
                                        {vehErr && <div style={{ fontSize:'11px', color:'#FCA5A5', marginTop:'4px' }}>{vehErr}</div>}
                                    </div>
                                    <button type="submit" style={{ padding:'8px 14px', borderRadius:'8px', background:'linear-gradient(135deg,#FFC107,#FF8F00)', color:'#121212', fontSize:'12px', fontWeight:700, border:'none', cursor:'pointer', whiteSpace:'nowrap', fontFamily:'Inter,sans-serif' }}>Add</button>
                                    <button type="button" onClick={() => { setAddingVeh(false); setVehErr(''); }} style={{ padding:'8px 12px', borderRadius:'8px', background:'rgba(255,255,255,.06)', border:'1px solid rgba(255,255,255,.1)', color:'#9E9E9E', fontSize:'12px', cursor:'pointer', fontFamily:'Inter,sans-serif' }}>Cancel</button>
                                </form>
                            ) : (
                                <button onClick={() => setAddingVeh(true)}
                                    style={{ marginTop:'8px', width:'100%', padding:'7px', borderRadius:'8px', fontSize:'12px', fontWeight:600, cursor:'pointer', border:'1px dashed rgba(255,255,255,.1)', background:'rgba(255,255,255,.02)', color:'#757575', fontFamily:'Inter,sans-serif', transition:'all .2s' }}
                                    onMouseOver={e=>e.currentTarget.style.borderColor='rgba(255,255,255,.2)'}
                                    onMouseOut={e=>e.currentTarget.style.borderColor='rgba(255,255,255,.1)'}
                                >+ Add Vehicle</button>
                            )}
                        </div>
                    )}
                </div>
            );
        }

        // ── Owner Summary Panel ─────────────────────────────────────────────────────────
        function OwnerSummary({ log }) {
            const summaries = (log.owners || []).filter(o => !o.is_disabled && o.name).map(o => {
                const loads = o.vehicles.filter(v => !v.is_disabled).flatMap(v => v.loads);
                const byMat = {}; LOAD_MATERIALS.forEach(m => byMat[m] = 0);
                loads.forEach(l => byMat[l.material] = (byMat[l.material] || 0) + 1);
                return { name: o.name, total: loads.length, paid: loads.filter(l => l.payment_status === 'paid').length,
                    unpaid: loads.filter(l => l.payment_status === 'unpaid').length,
                    passGiven: loads.filter(l => l.pass_given).length, byMat };
            });
            if (summaries.length === 0) return null;
            const grandTotal = summaries.reduce((s,o) => s + o.total, 0);
            return (
                <div style={{ marginTop:'20px', border:'1px solid rgba(255,193,7,.15)', borderRadius:'16px', overflow:'hidden' }}>
                    <div style={{ padding:'14px 18px', background:'rgba(255,193,7,.07)', borderBottom:'1px solid rgba(255,193,7,.1)', display:'flex', justifyContent:'space-between', alignItems:'center' }}>
                        <span style={{ fontWeight:700, fontSize:'14px', color:'#FFCA28' }}>📊 Owner Summary</span>
                        <span style={{ fontSize:'12px', color:'#757575' }}>Total: {grandTotal} loads</span>
                    </div>
                    {summaries.map((o, i) => (
                        <div key={i} style={{ padding:'12px 18px', borderBottom: i < summaries.length-1 ? '1px solid rgba(255,255,255,.05)' : 'none' }}>
                            <div style={{ display:'flex', justifyContent:'space-between', alignItems:'flex-start', marginBottom:'6px' }}>
                                <div>
                                    <span style={{ fontWeight:700, fontSize:'13px', color:'#fff' }}>👤 {o.name}</span>
                                    <div style={{ marginTop:'4px', display:'flex', flexWrap:'wrap', gap:'4px' }}>
                                        {LOAD_MATERIALS.filter(m => o.byMat[m] > 0).map(m => (
                                            <span key={m} style={{ fontSize:'10px', padding:'2px 7px', borderRadius:'5px', background:'rgba(255,255,255,.06)', color:'#9E9E9E' }}>{m}: {o.byMat[m]}</span>
                                        ))}
                                    </div>
                                </div>
                                <div style={{ textAlign:'right', flexShrink:0 }}>
                                    <div style={{ fontWeight:900, fontSize:'20px', color:'#FFCA28' }}>{o.total}</div>
                                    <div style={{ fontSize:'10px', color:'#757575' }}>loads</div>
                                </div>
                            </div>
                            <div style={{ display:'flex', gap:'8px', flexWrap:'wrap' }}>
                                <span style={{ fontSize:'11px', padding:'3px 9px', borderRadius:'6px', background:'rgba(34,197,94,.1)', color:'#86EFAC' }}>✓ Paid: {o.paid}</span>
                                <span style={{ fontSize:'11px', padding:'3px 9px', borderRadius:'6px', background:'rgba(239,68,68,.1)', color:'#FCA5A5' }}>✗ Unpaid: {o.unpaid}</span>
                                {o.passGiven > 0 && <span style={{ fontSize:'11px', padding:'3px 9px', borderRadius:'6px', background:'rgba(255,193,7,.1)', color:'#FFCA28' }}>🎫 Pass: {o.passGiven}</span>}
                            </div>
                        </div>
                    ))}
                </div>
            );
        }

        // ── DailyLogView ─────────────────────────────────────────────────────────────────
        function DailyLogView({ site, date, onBack }) {
            const [log, setLog] = useState(null);
            const [addingOwner, setAddingOwner] = useState(false);
            const [newOwnerName, setNewOwnerName] = useState('');
            const [newOwnerContact, setNewOwnerContact] = useState('');

            useEffect(() => {
                const built = buildLog(site.id, date);
                setLog(built);
                saveLog(site.id, date, built);
            }, [site.id, date]);

            function handleLogChange(updatedLog) {
                setLog(updatedLog);
                saveLog(site.id, date, updatedLog);
            }

            function addOwner(e) {
                e.preventDefault();
                if (!newOwnerName.trim()) return;
                const owner = { id: Date.now(), name: newOwnerName.trim(), contact: newOwnerContact.trim(),
                    is_default: false, is_disabled: false, is_open: true, vehicles: [] };
                handleLogChange({ ...log, owners: [...log.owners, owner] });
                setNewOwnerName(''); setNewOwnerContact(''); setAddingOwner(false);
            }

            function deleteOwner(idx) {
                handleLogChange({ ...log, owners: log.owners.filter((_, i) => i !== idx) });
            }

            if (!log) return <div style={{ textAlign:'center', color:'#424242', padding:'40px' }}>Loading…</div>;

            const totalLoads = log.owners.filter(o=>!o.is_disabled).reduce((s,o) => s + o.vehicles.filter(v=>!v.is_disabled).reduce((sv,v) => sv+v.loads.length, 0), 0);

            return (
                <div>
                    {/* Breadcrumb */}
                    <div style={{ display:'flex', alignItems:'center', gap:'8px', marginBottom:'16px', fontSize:'13px', color:'#616161', flexWrap:'wrap' }}>
                        <button onClick={() => onBack('sites')} style={{ background:'none', border:'none', color:'#757575', cursor:'pointer', fontFamily:'Inter,sans-serif', fontSize:'13px' }}
                            onMouseOver={e=>e.target.style.color='#FFCA28'} onMouseOut={e=>e.target.style.color='#757575'}>Sites</button>
                        <span>›</span>
                        <button onClick={() => onBack('dates')} style={{ background:'none', border:'none', color:'#757575', cursor:'pointer', fontFamily:'Inter,sans-serif', fontSize:'13px' }}
                            onMouseOver={e=>e.target.style.color='#FFCA28'} onMouseOut={e=>e.target.style.color='#757575'}>{site.name}</button>
                        <span>›</span>
                        <span style={{ color:'#E0E0E0', fontWeight:600 }}>{fmtDate(date)}</span>
                    </div>

                    {/* Header */}
                    <div style={{ display:'flex', justifyContent:'space-between', alignItems:'center', marginBottom:'16px', flexWrap:'wrap', gap:'10px' }}>
                        <div>
                            <h2 style={{ fontFamily:'Outfit,sans-serif', fontWeight:900, fontSize:'1.4rem', color:'#fff', margin:0 }}>Daily Log</h2>
                            <div style={{ fontSize:'12px', color:'#616161', marginTop:'4px' }}>📍 {site.name} · {site.location} · {fmtDate(date)}</div>
                        </div>
                        <div style={{ display:'flex', alignItems:'center', gap:'10px' }}>
                            <div style={{ padding:'6px 14px', borderRadius:'10px', background:'rgba(255,193,7,.08)', border:'1px solid rgba(255,193,7,.2)', fontSize:'13px', color:'#FFCA28', fontWeight:700 }}>
                                {totalLoads} loads today
                            </div>
                        </div>
                    </div>

                    {/* Owners */}
                    {log.owners.map((owner, idx) => (
                        <OwnerSection key={owner.id} owner={owner} ownerIdx={idx} log={log}
                            onLogChange={handleLogChange}
                            onDelete={() => deleteOwner(idx)} />
                    ))}

                    {/* Add Owner */}
                    {addingOwner ? (
                        <form onSubmit={addOwner} style={{ border:'1px solid rgba(255,193,7,.2)', borderRadius:'14px', padding:'16px', marginBottom:'10px', background:'rgba(255,193,7,.04)' }}>
                            <div style={{ fontSize:'12px', fontWeight:700, color:'#FFCA28', marginBottom:'10px', textTransform:'uppercase', letterSpacing:'.05em' }}>New Owner</div>
                            <div style={{ display:'flex', gap:'8px', flexWrap:'wrap' }}>
                                <input value={newOwnerName} onChange={e => setNewOwnerName(e.target.value)} placeholder="Owner name *" required autoFocus
                                    style={{ flex:'1 1 160px', background:'rgba(255,255,255,.06)', border:'1px solid rgba(255,255,255,.1)', borderRadius:'8px', padding:'9px 12px', color:'#fff', fontSize:'13px', outline:'none', fontFamily:'Inter,sans-serif' }} />
                                <input value={newOwnerContact} onChange={e => setNewOwnerContact(e.target.value)} placeholder="Contact (optional)"
                                    style={{ flex:'1 1 140px', background:'rgba(255,255,255,.06)', border:'1px solid rgba(255,255,255,.1)', borderRadius:'8px', padding:'9px 12px', color:'#fff', fontSize:'13px', outline:'none', fontFamily:'Inter,sans-serif' }} />
                                <button type="submit" style={{ padding:'9px 16px', borderRadius:'8px', background:'linear-gradient(135deg,#FFC107,#FF8F00)', color:'#121212', fontSize:'13px', fontWeight:700, border:'none', cursor:'pointer', whiteSpace:'nowrap', fontFamily:'Inter,sans-serif' }}>Add Owner</button>
                                <button type="button" onClick={() => setAddingOwner(false)} style={{ padding:'9px 14px', borderRadius:'8px', background:'rgba(255,255,255,.05)', border:'1px solid rgba(255,255,255,.1)', color:'#9E9E9E', fontSize:'13px', cursor:'pointer', fontFamily:'Inter,sans-serif' }}>Cancel</button>
                            </div>
                        </form>
                    ) : (
                        <button onClick={() => setAddingOwner(true)}
                            style={{ width:'100%', padding:'12px', borderRadius:'12px', fontSize:'13px', fontWeight:600, cursor:'pointer', border:'1px dashed rgba(255,193,7,.25)', background:'rgba(255,193,7,.04)', color:'#FFCA28', fontFamily:'Inter,sans-serif', transition:'all .2s', marginBottom:'16px' }}
                            onMouseOver={e=>e.currentTarget.style.background='rgba(255,193,7,.08)'}
                            onMouseOut={e=>e.currentTarget.style.background='rgba(255,193,7,.04)'}
                        >+ Add Owner</button>
                    )}

                    {/* Summary */}
                    <OwnerSummary log={log} />
                </div>
            );
        }

        // ── DateView ─────────────────────────────────────────────────────────────────────
        function DateView({ site, onBack, onSelectDate }) {
            const [selectedDate, setSelectedDate] = useState(() => new Date().toISOString().slice(0,10));
            const [existingDates, setExistingDates] = useState([]);

            useEffect(() => {
                // Scan localStorage for logs belonging to this site
                const dates = [];
                for (let i = 0; i < localStorage.length; i++) {
                    const key = localStorage.key(i);
                    if (key && key.startsWith(`kk_log_${site.id}_`)) {
                        dates.push(key.replace(`kk_log_${site.id}_`, ''));
                    }
                }
                setExistingDates(dates.sort().reverse());
            }, [site.id]);

            return (
                <div>
                    {/* Breadcrumb */}
                    <div style={{ display:'flex', alignItems:'center', gap:'8px', marginBottom:'16px', fontSize:'13px', color:'#616161' }}>
                        <button onClick={() => onBack('sites')} style={{ background:'none', border:'none', color:'#757575', cursor:'pointer', fontFamily:'Inter,sans-serif', fontSize:'13px' }}
                            onMouseOver={e=>e.target.style.color='#FFCA28'} onMouseOut={e=>e.target.style.color='#757575'}>Sites</button>
                        <span>›</span>
                        <span style={{ color:'#E0E0E0', fontWeight:600 }}>{site.name}</span>
                    </div>

                    <div style={{ display:'flex', justifyContent:'space-between', alignItems:'center', marginBottom:'20px', flexWrap:'wrap', gap:'10px' }}>
                        <div>
                            <h2 style={{ fontFamily:'Outfit,sans-serif', fontWeight:900, fontSize:'1.4rem', color:'#fff', margin:0 }}>{site.name}</h2>
                            <div style={{ fontSize:'12px', color:'#616161', marginTop:'4px' }}>📍 {site.location} · {fmtDate(site.start_date)} – {fmtDate(site.end_date)}</div>
                        </div>
                    </div>

                    {/* Date picker for new/existing */}
                    <div style={{ border:'1px solid rgba(255,255,255,.08)', borderRadius:'16px', padding:'20px', marginBottom:'16px', background:'rgba(255,255,255,.02)' }}>
                        <div style={{ fontSize:'11px', fontWeight:600, color:'#9E9E9E', textTransform:'uppercase', letterSpacing:'.06em', marginBottom:'12px' }}>Open a Date</div>
                        <div style={{ display:'flex', gap:'8px', alignItems:'center', flexWrap:'wrap' }}>
                            <input type="date" value={selectedDate} onChange={e => setSelectedDate(e.target.value)}
                                style={{ flex:'1 1 180px', background:'rgba(255,255,255,.06)', border:'1px solid rgba(255,255,255,.1)', borderRadius:'10px', padding:'10px 14px', color:'#fff', fontSize:'14px', outline:'none', fontFamily:'Inter,sans-serif', colorScheme:'dark' }} />
                            <button onClick={() => onSelectDate(selectedDate)}
                                style={{ padding:'10px 22px', borderRadius:'10px', background:'linear-gradient(135deg,#FFC107,#FF8F00)', color:'#121212', fontSize:'13px', fontWeight:700, border:'none', cursor:'pointer', whiteSpace:'nowrap', fontFamily:'Inter,sans-serif', boxShadow:'0 4px 14px rgba(255,193,7,.25)' }}
                                onMouseOver={e=>e.currentTarget.style.transform='translateY(-1px)'}
                                onMouseOut={e=>e.currentTarget.style.transform='none'}
                            >Open Log →</button>
                        </div>
                    </div>

                    {/* Past logs */}
                    {existingDates.length > 0 && (
                        <div style={{ border:'1px solid rgba(255,255,255,.06)', borderRadius:'16px', overflow:'hidden' }}>
                            <div style={{ padding:'12px 18px', background:'rgba(255,255,255,.03)', borderBottom:'1px solid rgba(255,255,255,.05)', fontSize:'11px', fontWeight:600, color:'#757575', textTransform:'uppercase', letterSpacing:'.06em' }}>Recent Logs</div>
                            {existingDates.slice(0,10).map(d => {
                                const dayLog = getRawLog(site.id, d) || { owners: [] };
                                const loads = dayLog.owners.reduce((s,o) => s + o.vehicles.reduce((sv,v) => sv+v.loads.length, 0), 0);
                                return (
                                    <div key={d} onClick={() => onSelectDate(d)}
                                        style={{ padding:'12px 18px', display:'flex', justifyContent:'space-between', alignItems:'center', cursor:'pointer', borderBottom:'1px solid rgba(255,255,255,.04)', transition:'background .15s' }}
                                        onMouseOver={e=>e.currentTarget.style.background='rgba(255,255,255,.04)'}
                                        onMouseOut={e=>e.currentTarget.style.background='transparent'}>
                                        <div>
                                            <div style={{ fontWeight:600, fontSize:'13px', color:'#fff' }}>{fmtDate(d)}</div>
                                            <div style={{ fontSize:'11px', color:'#616161', marginTop:'2px' }}>{dayLog.owners.filter(o=>o.name).length} owners</div>
                                        </div>
                                        <div style={{ display:'flex', alignItems:'center', gap:'10px' }}>
                                            <span style={{ fontSize:'12px', color:'#FFCA28', fontWeight:700 }}>{loads} loads</span>
                                            <span style={{ color:'#424242', fontSize:'12px' }}>›</span>
                                        </div>
                                    </div>
                                );
                            })}
                        </div>
                    )}
                </div>
            );
        }

        // ── SitesView ────────────────────────────────────────────────────────────────────
        function SitesView({ onSelectSite }) {
            const [sites, setSites] = useState(getSites());
            const [adding, setAdding] = useState(false);
            const [form, setForm] = useState({ name:'', location:'', start_date: new Date().toISOString().slice(0,10), end_date:'' });
            const [formErr, setFormErr] = useState('');

            function addSite(e) {
                e.preventDefault();
                if (!form.name.trim() || !form.location.trim()) { setFormErr('Name and location are required.'); return; }
                const site = { id: Date.now(), ...form, name: form.name.trim(), location: form.location.trim() };
                const updated = [...sites, site]; saveSites(updated); setSites(updated);
                setForm({ name:'', location:'', start_date: new Date().toISOString().slice(0,10), end_date:'' });
                setAdding(false); setFormErr('');
            }

            function deleteSite(id) {
                if (!confirm('Delete this site? All daily logs for this site will also be removed.')) return;
                // Remove all logs for this site
                const keysToRemove = [];
                for (let i = 0; i < localStorage.length; i++) {
                    const k = localStorage.key(i); if (k && k.startsWith(`kk_log_${id}_`)) keysToRemove.push(k);
                }
                keysToRemove.forEach(k => localStorage.removeItem(k));
                const updated = sites.filter(s => s.id !== id); saveSites(updated); setSites(updated);
            }

            return (
                <div>
                    <div style={{ display:'flex', justifyContent:'space-between', alignItems:'center', marginBottom:'20px', flexWrap:'wrap', gap:'10px' }}>
                        <div>
                            <p style={{ fontSize:'11px', fontWeight:600, color:'#FFCA28', textTransform:'uppercase', letterSpacing:'.08em', margin:'0 0 4px' }}>Daily Logistics</p>
                            <h2 style={{ fontFamily:'Outfit,sans-serif', fontWeight:900, fontSize:'1.6rem', color:'#fff', margin:0 }}>Sites</h2>
                        </div>
                        <button onClick={() => setAdding(a => !a)}
                            style={{ padding:'9px 18px', borderRadius:'10px', background:'linear-gradient(135deg,#FFC107,#FF8F00)', color:'#121212', fontSize:'13px', fontWeight:700, border:'none', cursor:'pointer', fontFamily:'Inter,sans-serif', boxShadow:'0 4px 14px rgba(255,193,7,.25)' }}
                        >{adding ? 'Cancel' : '+ New Site'}</button>
                    </div>

                    {/* Add site form */}
                    {adding && (
                        <form onSubmit={addSite} style={{ border:'1px solid rgba(255,193,7,.2)', borderRadius:'16px', padding:'20px 20px 16px', marginBottom:'16px', background:'rgba(255,193,7,.03)' }}>
                            <div style={{ fontSize:'11px', fontWeight:600, color:'#FFCA28', textTransform:'uppercase', letterSpacing:'.06em', marginBottom:'14px' }}>New Site Details</div>
                            <div style={{ display:'grid', gridTemplateColumns:'repeat(auto-fit,minmax(180px,1fr))', gap:'10px', marginBottom:'12px' }}>
                                <div>
                                    <label style={{ display:'block', fontSize:'10px', fontWeight:600, color:'#757575', textTransform:'uppercase', letterSpacing:'.05em', marginBottom:'6px' }}>Site Name *</label>
                                    <input value={form.name} onChange={e=>setForm({...form,name:e.target.value})} placeholder="e.g. Kollam Bridge Project" required
                                        style={{ width:'100%', boxSizing:'border-box', background:'rgba(255,255,255,.06)', border:'1px solid rgba(255,255,255,.1)', borderRadius:'8px', padding:'9px 12px', color:'#fff', fontSize:'13px', outline:'none', fontFamily:'Inter,sans-serif' }} />
                                </div>
                                <div>
                                    <label style={{ display:'block', fontSize:'10px', fontWeight:600, color:'#757575', textTransform:'uppercase', letterSpacing:'.05em', marginBottom:'6px' }}>Location *</label>
                                    <input value={form.location} onChange={e=>setForm({...form,location:e.target.value})} placeholder="e.g. Kallada, Kollam" required
                                        style={{ width:'100%', boxSizing:'border-box', background:'rgba(255,255,255,.06)', border:'1px solid rgba(255,255,255,.1)', borderRadius:'8px', padding:'9px 12px', color:'#fff', fontSize:'13px', outline:'none', fontFamily:'Inter,sans-serif' }} />
                                </div>
                                <div>
                                    <label style={{ display:'block', fontSize:'10px', fontWeight:600, color:'#757575', textTransform:'uppercase', letterSpacing:'.05em', marginBottom:'6px' }}>Start Date</label>
                                    <input type="date" value={form.start_date} onChange={e=>setForm({...form,start_date:e.target.value})}
                                        style={{ width:'100%', boxSizing:'border-box', background:'rgba(255,255,255,.06)', border:'1px solid rgba(255,255,255,.1)', borderRadius:'8px', padding:'9px 12px', color:'#fff', fontSize:'13px', outline:'none', fontFamily:'Inter,sans-serif', colorScheme:'dark' }} />
                                </div>
                                <div>
                                    <label style={{ display:'block', fontSize:'10px', fontWeight:600, color:'#757575', textTransform:'uppercase', letterSpacing:'.05em', marginBottom:'6px' }}>End Date (Pass Expiry)</label>
                                    <input type="date" value={form.end_date} onChange={e=>setForm({...form,end_date:e.target.value})}
                                        style={{ width:'100%', boxSizing:'border-box', background:'rgba(255,255,255,.06)', border:'1px solid rgba(255,255,255,.1)', borderRadius:'8px', padding:'9px 12px', color:'#fff', fontSize:'13px', outline:'none', fontFamily:'Inter,sans-serif', colorScheme:'dark' }} />
                                </div>
                            </div>
                            {formErr && <div style={{ fontSize:'12px', color:'#FCA5A5', marginBottom:'10px' }}>{formErr}</div>}
                            <button type="submit" style={{ padding:'9px 22px', borderRadius:'8px', background:'linear-gradient(135deg,#FFC107,#FF8F00)', color:'#121212', fontSize:'13px', fontWeight:700, border:'none', cursor:'pointer', fontFamily:'Inter,sans-serif' }}>Create Site</button>
                        </form>
                    )}

                    {/* Site list */}
                    {sites.length === 0 ? (
                        <div style={{ textAlign:'center', padding:'50px 20px', border:'1px dashed rgba(255,255,255,.07)', borderRadius:'16px' }}>
                            <div style={{ fontSize:'3rem', marginBottom:'12px' }}>🏗️</div>
                            <div style={{ color:'#616161', fontSize:'14px' }}>No sites yet. Create your first site above.</div>
                        </div>
                    ) : (
                        <div style={{ display:'flex', flexDirection:'column', gap:'8px' }}>
                            {sites.map(site => {
                                const today = new Date().toISOString().slice(0,10);
                                const expired = site.end_date && site.end_date < today;
                                return (
                                    <div key={site.id} onClick={() => onSelectSite(site)}
                                        style={{ border:'1px solid rgba(255,255,255,.07)', borderRadius:'14px', padding:'16px 18px', cursor:'pointer', background:'rgba(255,255,255,.02)', transition:'all .2s', display:'flex', justifyContent:'space-between', alignItems:'center', gap:'12px' }}
                                        onMouseOver={e=>{ e.currentTarget.style.background='rgba(255,255,255,.05)'; e.currentTarget.style.borderColor='rgba(255,193,7,.2)'; }}
                                        onMouseOut={e=>{ e.currentTarget.style.background='rgba(255,255,255,.02)'; e.currentTarget.style.borderColor='rgba(255,255,255,.07)'; }}>
                                        <div style={{ flex:1 }}>
                                            <div style={{ fontWeight:700, fontSize:'15px', color:'#fff', marginBottom:'4px' }}>{site.name}</div>
                                            <div style={{ fontSize:'12px', color:'#616161' }}>📍 {site.location}</div>
                                            {site.start_date && <div style={{ fontSize:'11px', color:'#424242', marginTop:'3px' }}>{fmtDate(site.start_date)}{site.end_date ? ` – ${fmtDate(site.end_date)}` : ''}</div>}
                                        </div>
                                        <div style={{ display:'flex', alignItems:'center', gap:'10px', flexShrink:0 }}>
                                            {expired && <span style={{ fontSize:'10px', padding:'3px 8px', borderRadius:'5px', background:'rgba(239,68,68,.1)', border:'1px solid rgba(239,68,68,.25)', color:'#FCA5A5' }}>Pass Expired</span>}
                                            <button onClick={e => { e.stopPropagation(); deleteSite(site.id); }}
                                                style={{ background:'none', border:'none', color:'#424242', cursor:'pointer', fontSize:'16px', padding:'2px 4px' }}
                                                onMouseOver={e=>e.target.style.color='#EF4444'} onMouseOut={e=>e.target.style.color='#424242'}>×</button>
                                            <span style={{ color:'#424242' }}>›</span>
                                        </div>
                                    </div>
                                );
                            })}
                        </div>
                    )}
                </div>
            );
        }

        // ── DefaultVehiclesPanel ─────────────────────────────────────────────────────────
        function DefaultVehiclesPanel() {
            const [open, setOpen] = useState(false);
            const [vehicles, setVehicles] = useState(getDefaultVehicles());
            const [adding, setAdding] = useState(false);
            const [newNum, setNewNum] = useState('');
            const [newOwner, setNewOwner] = useState('');
            const [err, setErr] = useState('');

            function addVeh(e) {
                e.preventDefault();
                const num = newNum.trim().toUpperCase();
                if (!num || !newOwner.trim()) { setErr('Both fields required.'); return; }
                if (vehicles.find(v => v.number.toLowerCase() === num.toLowerCase())) { setErr('Vehicle already exists.'); return; }
                const updated = [...vehicles, { id: Date.now(), number: num, owner_name: newOwner.trim() }];
                saveDefaultVehicles(updated); setVehicles(updated);
                setNewNum(''); setNewOwner(''); setAdding(false); setErr('');
            }
            function delVeh(id) {
                if (!confirm('Remove this default vehicle?')) return;
                const updated = vehicles.filter(v => v.id !== id); saveDefaultVehicles(updated); setVehicles(updated);
            }

            return (
                <div style={{ border:'1px solid rgba(255,255,255,.07)', borderRadius:'14px', marginBottom:'20px', overflow:'hidden' }}>
                    <div style={{ display:'flex', justifyContent:'space-between', alignItems:'center', padding:'12px 18px', background:'rgba(255,255,255,.03)', cursor:'pointer', borderBottom: open ? '1px solid rgba(255,255,255,.06)' : 'none' }}
                         onClick={() => setOpen(o => !o)}>
                        <div style={{ display:'flex', alignItems:'center', gap:'8px' }}>
                            <span style={{ fontSize:'14px' }}>🏢</span>
                            <span style={{ fontWeight:700, fontSize:'14px', color:'#E0E0E0' }}>Company Default Vehicles</span>
                            <span style={{ fontSize:'11px', padding:'2px 7px', borderRadius:'5px', background:'rgba(255,193,7,.1)', color:'#FFCA28' }}>{vehicles.length}</span>
                        </div>
                        <span style={{ color:'#424242', fontSize:'13px' }}>{open ? '▲' : '▼'}</span>
                    </div>
                    {open && (
                        <div style={{ padding:'14px 18px' }}>
                            {vehicles.length === 0 && !adding && (
                                <div style={{ color:'#424242', fontSize:'12px', textAlign:'center', padding:'10px 0' }}>No default vehicles. Add company vehicles here.</div>
                            )}
                            {vehicles.map(v => (
                                <div key={v.id} style={{ display:'flex', justifyContent:'space-between', alignItems:'center', padding:'8px 12px', borderRadius:'8px', background:'rgba(255,255,255,.03)', border:'1px solid rgba(255,255,255,.05)', marginBottom:'6px' }}>
                                    <div>
                                        <span style={{ fontWeight:700, fontSize:'13px', color:'#fff' }}>🚛 {v.number}</span>
                                        <span style={{ fontSize:'11px', color:'#616161', marginLeft:'8px' }}>({v.owner_name})</span>
                                    </div>
                                    <button onClick={() => delVeh(v.id)} style={{ background:'none', border:'none', color:'#424242', cursor:'pointer', fontSize:'16px' }}
                                        onMouseOver={e=>e.target.style.color='#EF4444'} onMouseOut={e=>e.target.style.color='#424242'}>×</button>
                                </div>
                            ))}
                            {adding ? (
                                <form onSubmit={addVeh} style={{ display:'flex', gap:'6px', flexWrap:'wrap', marginTop:'8px' }}>
                                    <input value={newNum} onChange={e=>{setNewNum(e.target.value);setErr('');}} placeholder="Vehicle number" required
                                        style={{ flex:'1 1 140px', background:'rgba(255,255,255,.06)', border:'1px solid rgba(255,255,255,.1)', borderRadius:'8px', padding:'8px 12px', color:'#fff', fontSize:'13px', outline:'none', fontFamily:'Inter,sans-serif' }} />
                                    <input value={newOwner} onChange={e=>{setNewOwner(e.target.value);setErr('');}} placeholder="Owner name" required
                                        style={{ flex:'1 1 130px', background:'rgba(255,255,255,.06)', border:'1px solid rgba(255,255,255,.1)', borderRadius:'8px', padding:'8px 12px', color:'#fff', fontSize:'13px', outline:'none', fontFamily:'Inter,sans-serif' }} />
                                    <button type="submit" style={{ padding:'8px 14px', borderRadius:'8px', background:'linear-gradient(135deg,#FFC107,#FF8F00)', color:'#121212', fontSize:'12px', fontWeight:700, border:'none', cursor:'pointer', fontFamily:'Inter,sans-serif' }}>Add</button>
                                    <button type="button" onClick={() => { setAdding(false); setErr(''); }} style={{ padding:'8px 12px', borderRadius:'8px', background:'rgba(255,255,255,.06)', border:'1px solid rgba(255,255,255,.1)', color:'#9E9E9E', fontSize:'12px', cursor:'pointer', fontFamily:'Inter,sans-serif' }}>Cancel</button>
                                    {err && <div style={{ width:'100%', fontSize:'11px', color:'#FCA5A5' }}>{err}</div>}
                                </form>
                            ) : (
                                <button onClick={() => setAdding(true)}
                                    style={{ marginTop:'8px', width:'100%', padding:'7px', borderRadius:'8px', fontSize:'12px', fontWeight:600, cursor:'pointer', border:'1px dashed rgba(255,193,7,.25)', background:'rgba(255,193,7,.04)', color:'#FFCA28', fontFamily:'Inter,sans-serif' }}
                                >+ Add Default Vehicle</button>
                            )}
                        </div>
                    )}
                </div>
            );
        }

        // ── LogisticsPage ────────────────────────────────────────────────────────────────
        function LogisticsPage() {
            const [view, setView] = useState('sites');   // 'sites' | 'dates' | 'log'
            const [selectedSite, setSelectedSite] = useState(null);
            const [selectedDate, setSelectedDate] = useState(null);

            function goBack(to) {
                if (to === 'sites') { setView('sites'); setSelectedSite(null); setSelectedDate(null); }
                if (to === 'dates') { setView('dates'); setSelectedDate(null); }
            }

            return (
                <div className="pt-24 pb-16 px-4 min-h-screen">
                    <div style={{ maxWidth:'760px', margin:'0 auto' }}>
                        <DefaultVehiclesPanel />
                        <div className="glass-card rounded-3xl p-6 md:p-8" style={{ border:'1px solid rgba(255,255,255,.06)' }}>
                            {view === 'sites' && (
                                <SitesView onSelectSite={site => { setSelectedSite(site); setView('dates'); }} />
                            )}
                            {view === 'dates' && selectedSite && (
                                <DateView site={selectedSite} onBack={goBack}
                                    onSelectDate={date => { setSelectedDate(date); setView('log'); }} />
                            )}
                            {view === 'log' && selectedSite && selectedDate && (
                                <DailyLogView site={selectedSite} date={selectedDate} onBack={goBack} />
                            )}
                        </div>
                    </div>
                </div>
            );
        }

        // ─── ROOT ──────────────────────────────────────────────────────────────────────
        function App() {
            const [page, navigate] = useRoute();
            useEffect(() => { window.scrollTo({ top: 0, behavior: 'smooth' }); }, [page]);
            return (
                <div className="flex flex-col min-h-screen">
                    <Navbar page={page} navigate={navigate} />
                    <main className="flex-1">
                        {page === 'home'       && <HomePage navigate={navigate} />}
                        {page === 'calculator' && <CalculatorPage />}
                        {page === 'logistics'  && <LogisticsPage />}
                        {page === 'admin'      && <AdminPage />}
                        {page === 'contact'    && <ContactPage />}
                    </main>
                    <Footer navigate={navigate} />
                </div>
            );
        }

        ReactDOM.createRoot(document.getElementById('root')).render(<App />);
    </script>
</body>

</html>